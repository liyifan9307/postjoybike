<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    {%- render 'section-variables', section: section -%}
  }
  @media(max-width: 768px) {
      #shopify-section-{{ section.id }} {
        --section-padding-top: calc({{ section.settings.padding_top_mobile | append: 'px' }} / 0.75);
        --section-padding-bottom: calc({{ section.settings.padding_bottom_mobile | append: 'px' }} / 0.75);
      }
  }
  #shopify-section-{{ section.id }} .yg-brand {
    box-sizing: border-box;
    width: 100%;
    /* padding: 96px 0; */
  }

  #shopify-section-{{ section.id }} .yg-swiper-one {
    display: flex;
    overflow: visible;
    align-items: center;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper {
    display: flex;
    align-items: center;
    justify-content: start;
    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
  }

  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide {
    font-size: 32px;
    font-weight: 700;
    height: 100%;
    opacity: .3;
    color: #000000;
  }


  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide-active{
    opacity: 1; /* 50% 透明度 */
  }

  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide .item-header{
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* height: 250px; */

  }

  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide .top-img {
    width: 30px;
    height: 23px;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide .bottom-img{
    width: 30px;
    height: 23px;
    margin-left: auto;
  }

  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide .item-content{
    line-height: 140%;
    letter-spacing: -.32px;
    margin: 12px 0;
  }

  #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide .signature{
    font-size: 20px;
    font-weight: 700;
    /* line-height: 28px; */
    /* height: 28px; */
    margin-top: 18px;
  }

  #shopify-section-{{ section.id }} .swiper-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 66.7px;
    margin-top: 48px;
  }

  #shopify-section-{{ section.id }} .button:after,
  #shopify-section-{{ section.id }} .button:after{
    border-width: 1px;
  }
  #shopify-section-{{ section.id }} .swiper-button-prev .button,
  #shopify-section-{{ section.id }} .swiper-button-next .button{
    width: 52px;
    height: 52px;
    padding: 16px;
  }

  #shopify-section-{{ section.id }} .swiper-bottom .swiper-button-prev,
  #shopify-section-{{ section.id }} .swiper-bottom .swiper-button-next{
    /* display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #FFFFFF; */
    position: relative;
    display: block;
    top: 0;
    width:unset;
    height: unset;
    margin-top: 0;
    left:unset;
    right: unset;
  }

  #shopify-section-{{ section.id }} .swiper-button-next svg,
  #shopify-section-{{ section.id }} .swiper-button-prev svg{
    width: var(--sp-5d5);
    height: var(--sp-5d5);
  }

  #shopify-section-{{ section.id }} .swiper-bottom .yg-swiper-two {
    display: flex;
    overflow: hidden;
    align-items: center;
    justify-content: space-between;
    width: 87%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .yg-swiper-two .swiper-wrapper {
    height: 100%;
    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
  }

  #shopify-section-{{ section.id }} .yg-swiper-two .swiper-wrapper .swiper-slide{
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    height: 100%;
    opacity: 1;
    border-radius: 12px;
    background: #FFFFFF;
  }

  #shopify-section-{{ section.id }} .yg-swiper-two .swiper-wrapper .swiper-slide-active{
    border: 2px solid #000;
  }

  #shopify-section-{{ section.id }} .swiper-bottom .yg-swiper-two .image {
      width: 152px;
  }



  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .yg-swiper-one .swiper-wrapper .swiper-slide {
      font-size: 22px;
    }

    #shopify-section-{{ section.id }} .yg-brand {
      width: 100%;
    }
    #shopify-section-{{ section.id }} .swiper-bottom .yg-swiper-two .image {
      width: 100px;
    }
    #shopify-section-{{ section.id }} .swiper-bottom .yg-swiper-two {
      width: 65%;
    }

  }
</style>

{%- capture section_heading -%}
  {%- render 'section-heading', section: section -%}
{%- endcapture -%}

