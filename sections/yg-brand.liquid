                      </svg>
                    </div>
                  </div>
                  {% if block.settings.name != blank %}
                    <div class="signature">{{ block.settings.name }}</div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </div>
          <!-- 如果需要导航按钮 -->
          <div class="swiper-bottom">
            <div class="swiper-button-prev">
              <button class="button button--secondary" type="button" is="previous-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
                </span>
              </button>
            </div>
            <div class="swiper-image yg-swiper-two">
              <div class="swiper-wrapper">
                {% for block in section.blocks %}
                  {% assign img = block.settings.image %}
                  <div class="swiper-slide">
                    {%- if img != blank -%}
                      {{-
                        img
                        | image_url: width: img.width
                        | image_tag: preload: 'lazy', class: 'image', alt: img.alt
                      -}}
                    {%- endif -%}
                  </div>
                {% endfor %}
              </div>
            </div>
            <div class="swiper-button-next">
              <button class="button button--secondary" type="button" is="next-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
                </span>
              </button>
            </div>
          </div>
        </div>
      </yg-brand-swiper>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    class YGBrand extends HTMLElement {
      constructor() {
        super();
        this.init();
      }
      init() {
        this.swiperStyle();
      }
      swiperStyle() {
        let swiper1 = new Swiper('.yg-swiper-one', {
          direction: 'horizontal',
          allowTouchMove: true, // 确保允许触摸拖动
          slidesPerView: 1,
          spaceBetween: 30,
          loop: true, // 循环模式选项
          loopedSlides: {{ section.blocks.size }}, // 关键配置
          loopAdditionalSlides: 2,
          breakpoints: {
            1240: {
              slidesPerView: 1.6,
              spaceBetween: 90,
            },
          },
        });

        let swiper2 = new Swiper('.yg-swiper-two', {
          direction: 'horizontal',
          slidesPerView: 1.4,
          // slidesPerView: 1.4,
          spaceBetween: 21,
          centeredSlides: true,
          initialSlide: Math.floor({{ section.blocks.size }} / 2), // 初始显示中间slide
          loopedSlides: {{ section.blocks.size }}, // 关键配置
          loop: true,
          controller: {
            control: swiper1, //控制yg-swiper-one
          },
          // 如果需要前进后退按钮
          navigation: {
            nextEl: this.querySelector('.swiper-button-next'),
            prevEl: this.querySelector('.swiper-button-prev'),
          },
          on:{
            click: function(swiper, event){
              if (swiper.clickedIndex !== undefined) {
                let Difference = swiper.clickedIndex - swiper.activeIndex;
                if (Difference > 0) {
                  if (Difference != 1) {
                    swiper.slideTo(swiper.clickedIndex - 1, 0, true)
                  }
                  swiper.slideNext();
                  return;
                }

                if (Difference < 0) {
                  if (Difference != -1) {
                    swiper.slideTo(swiper.clickedIndex + 1, 0, true)
                  }
                  swiper.slidePrev();
                  return;
                }
              }
            },
          },
          breakpoints: {
            1240: {
              slidesPerView: 5.6,
              spaceBetween: 21,
            },
          },
        });
        swiper1.controller.control = swiper2; //yg-swiper-one控制yg-swiper-two，需要在yg-swiper-two初始化后
        swiper2.controller.control = swiper1; //yg-swiper-two控制yg-swiper-one，需要在yg-swiper-one初始化后

      }
    }

    if (!window.customElements.get('yg-brand-swiper')) {
      window.customElements.define('yg-brand-swiper', YGBrand);
    }
  });
</script>

{% schema %}
{
  "name": "YG Brand",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.global.settings.header__heading.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.global.settings.heading.label",
      "default": "Multimedia collage"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "title-sm",
          "label": "t:sections.global.settings.heading_size.options__1.label"
        },
        {
          "value": "title-md",
          "label": "t:sections.global.settings.heading_size.options__2.label"
        },
        {
          "value": "title-lg tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__3.label"
        },
        {
          "value": "title-xl tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__4.label"
        }
      ],
      "default": "title-md",
      "label": "t:sections.global.settings.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.global.settings.heading_alignment.label",
      "options": [
        {
          "value": "text-left md:items-end md:flex-row",
          "label": "t:sections.global.settings.heading_alignment.options__1.label"
        },
        {
          "value": "text-center md:items-center",
          "label": "t:sections.global.settings.heading_alignment.options__2.label"
        },
        {
          "value": "text-right md:items-end md:flex-row-reverse",
          "label": "t:sections.global.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "text-left md:items-end md:flex-row"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.global.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.global.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.global.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.global.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.global.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.global.settings.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.global.settings.heading_tag.options__7.label"
        },
        {
          "value": "span",
          "label": "t:sections.global.settings.heading_tag.options__8.label"
        },
        {
          "value": "p",
          "label": "t:sections.global.settings.heading_tag.options__9.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.global.settings.heading_tag.label",
      "info": "t:sections.global.settings.heading_tag.info"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.global.settings.subheading.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.global.settings.description.label",
      "default": "<p>Share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.global.settings.button_label.label",
      "info": "t:sections.global.settings.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.global.settings.button_link.label"
    },
    {
      "type": "checkbox",
      "id": "button_external",
      "label": "t:sections.global.settings.button_external.label",
      "default": false
    },
    {
