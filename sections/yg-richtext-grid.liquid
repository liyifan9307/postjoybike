<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
  #shopify-section-{{ section.id }} .yg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .yg-grid-block {
    margin:0;
    border-radius: 16px;
    background: #FFFAF2;
    backdrop-filter: blur(12px);
    padding: 20px;
  }
  #shopify-section-{{ section.id }} .collage.with-richtext,
  #shopify-section-{{ section.id }} .collage.with-richtext .title-wrapper, .collage.with-richtext .rich-text {
    padding-inline: 0;
  }
  #shopify-section-{{ section.id }} .yg-grid-icon img.yg-image{
    width: 48px;
    height: 48px;
  }
  #shopify-section-{{ section.id }} .yg-grid-title {
    margin-top: 16px;
    margin-bottom: 4px;
    color: #000;
    text-align: left;
    font-size: var(--yg-h4);
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
  }
  #shopify-section-{{ section.id }} .yg-grid-unit {
    margin-left: 4px;
    color: #F90;
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
  }
  #shopify-section-{{ section.id }} .yg-grid-sub {
    color: #000;
    text-align: left;
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 140%;
  }
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .yg-grid {
      gap: 8px;
    }
    #shopify-section-{{ section.id }} .yg-grid-block {
      border-radius: 12px;
      padding: 16px 12px;
    }
    #shopify-section-{{ section.id }} .yg-grid-icon img.yg-image{
      width: 32px;
      height: 32px;
    }
    #shopify-section-{{ section.id }} .yg-grid-title {
      margin-top: 8px;
      margin-bottom: 2px;
    }
    #shopify-section-{{ section.id }} .yg-grid-unit {
      font-size: 14px;
    }
  }
</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.narrow %} page-width--narrow{% endif %} relative">
    {%- capture section_heading -%}
      {%- render 'section-heading', section: section -%}
    {%- endcapture -%}

    {%- if section_heading != blank -%}
      <div class="collage collage-{{ section.settings.heading_width }} with-richtext grid items-start">
        {{- section_heading -}}
    {%- endif -%}

    <div class="rich-text md:text-{{ section.settings.text_alignment }} text-{{ section.settings.text_alignment_mobile }} relative z-1 yg-grid">
      {%- for block in section.blocks -%}
        {% assign icon = block.settings.icon %}
        {% assign title = block.settings.title %}
        {% assign unit = block.settings.unit %}
        {% assign sub = block.settings.sub %}
        <div class="yg-grid-block">
          {% if icon != blank %}
              <div class="yg-grid-icon">
                {{ icon | image_url: width: icon.width | image_tag: loading: 'lazy', alt: title, fetchpriority: 'low', class: 'yg-image' }}
              </div>
          {% endif %}

          {% if title != blank %}
            <p class="yg-grid-title">{{ title }}<span class="yg-grid-unit">{{ unit }}</span></p>
          {% endif %}

          {% if sub != blank %}
            <p class="yg-grid-sub">{{ sub }}</p>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>

    {%- if section_heading != blank -%}
      </div>
    {%- endif -%}
  </div>
</div>

