<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}

    overflow: hidden;
  }

  #shopify-section-{{ section.id }}   .slider+:is(p,.indicators){
    justify-content: end;
  }
  #shopify-section-{{ section.id }}  .button:after{
    border-width: 1px;
  }
  #shopify-section-{{ section.id }}   .yg-swiper-btn{
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .swiper{
    overflow: visible;
  }
  #shopify-section-{{ section.id }} .swiper-button-next,
  #shopify-section-{{ section.id }} .swiper-button-prev{
    position: relative;
    display: block;
    top: 0;
    width:unset;
    height: unset;
    margin-top: 0;
    left:unset;
    right: unset;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar-drag {
    display: block;
    height: 6px;
    background-color: #FF9900;
  }
  #shopify-section-{{ section.id }} .swiper-button-next svg,
  #shopify-section-{{ section.id }} .swiper-button-prev svg{
    width: var(--sp-5d5);
    height: var(--sp-5d5);
  }
  #shopify-section-{{ section.id }}  .yg-indicator {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 32px;
    gap: 48px;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar.swiper-scrollbar-horizontal{
    position: relative;
    height: 6px;
    left: 0;
    bottom: 0;
    top: 0;
  }

  #shopify-section-{{ section.id }} .yg-no-swiper .swiper-wrapper{
    display: grid;
    grid-template-columns: repeat(3,1fr);
    --card-grid-gap: var(--sp-4);
    gap: var(--card-grid-gap);
  }
  #shopify-section-{{ section.id }} .yg-no-swiper .yg-indicator{
    display: none;
  }

  #shopify-section-{{ section.id }} .swiper-button-next:after,
  #shopify-section-{{ section.id }} .swiper-button-prev:after {
    display: none;
  }

  #shopify-section-{{ section.id }} .yg-image-box {
    border-radius: 16px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .yg-title {
    color: #000;
    font-size: var(--yg-h5);
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
    margin-top: 16px;
  }
  #shopify-section-{{ section.id }} .yg-content {
    margin-top: 8px;
    color: #575553;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 140%;
  }
  #shopify-section-{{ section.id }} .yg-open-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }}   .yg-swiper-btn{
      gap: 12px;
    }
    #shopify-section-{{ section.id }}  .yg-indicator {
      margin-top: 16px;
      gap: 20px;
    }
    #shopify-section-{{ section.id }} .indicators .button{
      width: 40px;
      height: 40px;
    }
  }
</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- render 'section-heading', section: section -%}

    <yg-features class="yg-collections">
      <div class="swiper">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            {%- liquid
              assign image = block.settings.image
              assign title = block.settings.title
              assign content = block.settings.content

              assign videoi = block.settings.video
              assign external_video_url = block.settings.external_video_url
            %}

            <div class="swiper-slide yg-slide">
              {% if image != blank %}
                <div class="yg-image-box relative">
                  {{ image | image_url: width: image.width | image_tag: load: 'lazy', alt: title, class: 'yg-image' }}

                  {% if external_video_url != blank or videoi != blank %}
                    <yg-open-popup class="yg-open-btn">
                      <button type="button">
                        <span class="sr-only">{{ 'general.accessibility.play_video' | t }}</span>
                        {% render 'yg-icon', icon: 'yg-play-button' %}
                      </button>
                      <template>
                        {%- if block.settings.video != blank -%}
                          {{-
                            block.settings.video
                            | video_tag:
                              playsinline: true,
                              preload: 'metadata',
                              autoplay: true,
                              muted: true,
                              loop: true,
                              controls: true,
                              image_size: '100%'
                          -}}
                        {% else %}
                          {%- if block.settings.video_url.type == 'youtube' -%}
                            <iframe
                              src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?playsinline=1&autoplay=1&controls=0&mute=0&loop=1&playlist={{ block.settings.video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}"
                              allow="autoplay; encrypted-media"
                              allowfullscreen="allowfullscreen"
                            ></iframe>
                          {%- elsif block.settings.video_url.type == 'vimeo' -%}
                            <iframe
                              src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autopause=1&}background=1&autoplay=1&loop=1&muted=0&transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}"
                              allow="autoplay; encrypted-media;"
                              allowfullscreen="allowfullscreen"
                            ></iframe>
                          {%- endif -%}
                        {%- endif -%}
                      </template>
                    </yg-open-popup>
                  {% endif %}
                </div>
              {% endif %}

              {% if title != blank %}
                <p class="yg-title">{{ title }}</p>
              {% endif %}

              {% if content != blank %}
                <p class="yg-content">{{ content }}</p>
              {% endif %}
            </div>
          {%- endfor -%}
        </div>

        <div class="yg-indicator indicators hidden lg:flex gap-2d5">
          <div class="swiper-scrollbar"></div>
          <div class="yg-swiper-btn">
            <div class="swiper-button-prev">
              <button class="button button--secondary" type="button" is="previous-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
                </span>
              </button>
            </div>
            <div class="swiper-button-next">
              <button class="button button--secondary" type="button" is="next-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
                </span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </yg-features>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    class YGFeatures extends HTMLElement {
      constructor() {
        super();
        this.swiperInstance = null;
      }

      connectedCallback() {
        this.collectionsw();
      }

      disconnectedCallback() {
        this.destroySwiper();
      }

      destroySwiper() {
        if (this.swiperInstance) {
          this.swiperInstance.destroy(true);
          this.swiperInstance = null;
          this.querySelector('.swiper')?.classList.remove('swiper-initialized', 'swiper-horizontal');
          this.querySelector('.swiper')?.classList.add('yg-no-swiper');
        }
      }

      collectionsw() {
        const $swiper = this.querySelector('.swiper');

        this.destroySwiper();

        if ($swiper) {
          $swiper.classList.remove('yg-no-swiper');

          this.swiperInstance = new Swiper($swiper, {
            slidesPerView: 1.2,
            spaceBetween: 15,
            breakpoints: {
              390: {
                slidesPerView: 1.2,
                spaceBetween: 14,
              },
              1025: {
                slidesPerView: 3,
                spaceBetween: 24,
              },
            },
            scrollbar: {
              el: '.swiper-scrollbar',
              clickable: true,
            },
            navigation: {
              nextEl: '.swiper-button-next',
              prevEl: '.swiper-button-prev',
            },
          });
        } else {
          $swiper?.classList.add('yg-no-swiper');
        }
      }
    }

    if (!window.customElements.get('yg-features')) {
      window.customElements.define('yg-features', YGFeatures);
    }
  });
</script>

