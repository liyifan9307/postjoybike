{% comment %}
  Section: F30 Creator Reviews
  File name: sections/f30-creator-reviews.liquid
{% endcomment %}

<section
  id="f30-creator-reviews-{{ section.id }}"
  class="f30-creator-reviews"
>
  <div class="f30-creator-reviews__container">
    <div class="f30-creator-reviews__header">
      {% if section.settings.eyebrow != blank %}
        <p class="f30-creator-reviews__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="f30-creator-reviews__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="f30-creator-reviews__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="f30-creator-reviews__slider-wrap">
        <div class="f30-creator-reviews__grid" role="list">
          {% for block in section.blocks %}
            <article
              class="f30-creator-reviews__card"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <div class="f30-creator-reviews__meta">
                {% if block.settings.product != blank %}
                  <span>{{ block.settings.product }}</span>
                {% endif %}

                {% if block.settings.platform != blank %}
                  <span>{{ block.settings.platform }}</span>
                {% endif %}
              </div>

              {% if block.settings.creator != blank %}
                <h3 class="f30-creator-reviews__card-title">
                  {{ block.settings.creator }}
                </h3>
              {% endif %}

              {% if block.settings.review_text != blank %}
                <div class="f30-creator-reviews__card-text">
                  {{ block.settings.review_text }}
                </div>
              {% endif %}

              {% if block.settings.link != blank %}
                <a
                  class="f30-creator-reviews__button"
                  href="{{ block.settings.link }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open {{ block.settings.platform | escape }} review by {{ block.settings.creator | escape }}"
                >
                  {% if block.settings.button_label != blank %}
                    {{ block.settings.button_label }}
                  {% else %}
                    View Review
                  {% endif %}
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </div>

      {% if section.settings.show_mobile_hint %}
        <p class="f30-creator-reviews__mobile-hint">
          Swipe to see more reviews
        </p>
      {% endif %}
    {% endif %}
  </div>
</section>

<style>
  #f30-creator-reviews-{{ section.id }} {
    width: 100%;
    background:
      radial-gradient(circle at top left, rgba(0, 148, 255, 0.2), transparent 34%),
      radial-gradient(circle at bottom right, rgba(47, 95, 255, 0.14), transparent 32%),
      linear-gradient(180deg, {{ section.settings.background_color }} 0%, {{ section.settings.background_color_bottom }} 100%);
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
    box-sizing: border-box;
    overflow: hidden;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__header {
    max-width: 780px;
    margin: 0 auto 44px;
    text-align: {{ section.settings.header_alignment }};
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__eyebrow {
    margin: 0 0 12px;
    color: {{ section.settings.accent_color }};
    font-size: 14px;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__heading {
    margin: 0 0 16px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.08;
    font-weight: 900;
    letter-spacing: -0.03em;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__description {
    margin: 0;
    color: {{ section.settings.muted_text_color }};
    font-size: 17px;
    line-height: 1.7;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__description p {
    margin: 0;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__slider-wrap {
    width: 100%;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.card_gap }}px;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: {{ section.settings.card_min_height }}px;
    padding: 24px;
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    background:
      linear-gradient(180deg, {{ section.settings.card_background_top }} 0%, {{ section.settings.card_background_bottom }} 100%);
    box-shadow: 0 18px 42px rgba(0, 20, 45, 0.32);
    box-sizing: border-box;
    overflow: hidden;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent 38%),
      radial-gradient(circle at top right, rgba(0, 148, 255, 0.22), transparent 42%);
    opacity: 0.8;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__meta,
  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card-title,
  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card-text,
  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__button {
    position: relative;
    z-index: 1;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__meta span {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 5px 10px;
    border-radius: 999px;
    background: {{ section.settings.badge_background }};
    color: {{ section.settings.badge_text_color }};
    font-size: 12px;
    line-height: 1;
    font-weight: 800;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card-title {
    margin: 0 0 12px;
    color: {{ section.settings.heading_color }};
    font-size: 22px;
    line-height: 1.25;
    font-weight: 900;
    letter-spacing: -0.01em;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card-text {
    margin: 0 0 22px;
    color: {{ section.settings.card_text_color }};
    font-size: 15px;
    line-height: 1.65;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card-text p {
    margin: 0;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__button {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    font-size: 14px;
    line-height: 1;
    font-weight: 900;
    text-decoration: none;
    transition:
      transform 0.22s ease,
      background-color 0.22s ease,
      color 0.22s ease,
      box-shadow 0.22s ease;
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__button:hover {
    transform: translateY(-2px);
    background: {{ section.settings.button_hover_background }};
    color: {{ section.settings.button_hover_text_color }};
    box-shadow: 0 12px 26px rgba(0, 148, 255, 0.28);
  }

  #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__mobile-hint {
    display: none;
    margin: 14px 0 0;
    color: {{ section.settings.muted_text_color }};
    font-size: 13px;
    line-height: 1.4;
    text-align: center;
    opacity: 0.82;
  }

  @media screen and (max-width: 989px) {
    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__heading {
      font-size: calc({{ section.settings.heading_size }}px * 0.82);
    }
  }

  @media screen and (max-width: 749px) {
    #f30-creator-reviews-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
      padding-left: 0;
      padding-right: 0;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__container {
      max-width: 100%;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__header {
      margin-bottom: 32px;
      padding-left: 16px;
      padding-right: 16px;
      text-align: {{ section.settings.mobile_header_alignment }};
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__eyebrow {
      font-size: 12px;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: 1.12;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__description {
      font-size: 15px;
      line-height: 1.65;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__slider-wrap {
      position: relative;
      width: 100%;
      overflow: hidden;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__slider-wrap::after {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      width: 46px;
      height: 100%;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        rgba(6, 12, 24, 0),
        {{ section.settings.background_color_bottom }}
      );
      z-index: 2;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__grid {
      display: flex;
      grid-template-columns: none;
      gap: 16px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-left: 16px;
      padding-left: 16px;
      padding-right: 42px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__grid::-webkit-scrollbar {
      display: none;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card {
      flex: 0 0 {{ section.settings.mobile_card_width }}%;
      min-width: 0;
      min-height: {{ section.settings.mobile_card_min_height }}px;
      padding: 20px;
      border-radius: calc({{ section.settings.card_radius }}px * 0.85);
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card-title {
      font-size: 20px;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__card-text {
      font-size: 14px;
      line-height: 1.6;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__button {
      width: 100%;
      min-height: 46px;
    }

    #f30-creator-reviews-{{ section.id }} .f30-creator-reviews__mobile-hint {
      display: block;
      padding-left: 16px;
      padding-right: 16px;
    }
  }
</style>

{% schema %}
