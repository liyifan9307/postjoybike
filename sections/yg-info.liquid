<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
  #shopify-section-{{ section.id }} .yg-title-box {
    display: flex;
    align-items: center;
    padding-bottom: 12px;
    border-bottom: 1px solid #E6E5E5;
    margin-bottom: 32px;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .yg-title-box .yg-arrow-down{
    margin-left: auto;
    transition: transform .3s ease;
    width: 40px;
    height: 40px;
  }
  #shopify-section-{{ section.id }} .yg-title-box.yg-hide .yg-arrow-down{
    transform: rotate(180deg);
  }
  #shopify-section-{{ section.id }} .yg-content-box {
    transition: height .3s ease;
  }
  #shopify-section-{{ section.id }} .yg-content-box p{
    color: #000;
    color: {{ section.settings.color_text }};
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 140%;
  }
  #shopify-section-{{ section.id }} .yg-content-box h3{
    margin-top: 32px;
    margin-bottom: 8px;
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} .yg-title{
    color: #000;
    color: {{ section.settings.color_text }};
    font-size: var(--yg-h3);
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
    letter-spacing: -0.32px;
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .yg-content-box p{
      font-size: 14px;
    }
    #shopify-section-{{ section.id }} .yg-content-box h3{
      margin-top: 16px;
    }
    #shopify-section-{{ section.id }} .yg-title{
      max-width: 76%;
    }
  }
</style>

{%- capture section_heading -%}
  {%- render 'section-heading', section: section -%}
{%- endcapture -%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    <div class="collage on-scroll{% if section_heading == blank %} without-heading{% endif %} grid items-center">
      {{- section_heading -}}
      <yg-info>
        {% if section.settings.title != blank %}
          <div class="yg-title-box" is="title-box">
            <h2 class="h2 yg-title">{{ section.settings.title }}</h2>
            {%- render 'icon', icon: 'yg-arrow-down', class: 'yg-arrow-down' -%}
          </div>
        {% endif %}

        {% if section.settings.richtext != blank %}
          <div class="yg-content-box" is="content-box">{{section.settings.richtext}}</div>
        {% endif %}
      </yg-info>
    </div>
  </div>
</div>

