<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }

  #shopify-section-{{ section.id }} .yg-list {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .yg-item{

    margin-top: var(--yg-mt);
    margin-bottom: var(--yg-mt);
    
    display: flex;
    border-radius: 24px;
    overflow: hidden;
    background: #FFF;
    box-shadow: 0px 0px 24px 0px rgba(0, 0, 0, 0.12);
  }
  #shopify-section-{{ section.id }} .yg-info-box,
  #shopify-section-{{ section.id }} .yg-image-box{
    width: 50%;
  }
  #shopify-section-{{ section.id }} .yg-image-box img.yg-image{
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .yg-info-box {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 48px;
    padding-right: 48px;
  }
  #shopify-section-{{ section.id }} .yg-title {
    color: #000;
    font-size: var(--yg-h2);
    font-style: normal;
    font-weight: 700;
    line-height: 120%;
    letter-spacing: -0.48px;
  }
  #shopify-section-{{ section.id }} .yg-title strong{
    color: #f90;
  }
  #shopify-section-{{ section.id }} .yg-content {
    margin-top: 24px;
    color: #575553;
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: 140%;
  }
  #shopify-section-{{ section.id }} .yg-param-box {
    margin-top: 48px;
    display: flex;
  }
  #shopify-section-{{ section.id }} .yg-param-box .yg-param{
    flex:1;
  }
  #shopify-section-{{ section.id }} .yg-param-box .yg-param .yg-param-title{
    border-radius: 8px;
    background: #FFFAF2;
    padding: 4px 18px;
    color: #F90;
    font-size: 20px;
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
    width: max-content;
    margin-bottom:8px;
  }
  #shopify-section-{{ section.id }} .yg-param-box .yg-param .yg-param-content strong{
    color: #000;
    font-size: 22px;
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .yg-reverse {
      flex-direction: row-reverse;
    }
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .yg-list {
    }
    #shopify-section-{{ section.id }} .yg-item{
      margin-top: calc(var(--yg-mt) * 0.5);
      margin-bottom: calc(var(--yg-mb) * 0.5);

      flex-direction: column;
      box-shadow: none;
      border-radius: unset;
    }
    #shopify-section-{{ section.id }} .yg-info-box,
    #shopify-section-{{ section.id }} .yg-image-box{
      width: 100%;
    }
    #shopify-section-{{ section.id }} .yg-image{
      height: auto;
      border-radius: 12px;
    }
    #shopify-section-{{ section.id }} .yg-info-box {
      padding:0;
    }
    #shopify-section-{{ section.id }} .yg-title{
      margin-top: 20px;
      line-height: 120%;
      letter-spacing: -0.32px;
    }
    #shopify-section-{{ section.id }} .yg-content {
      margin-top:14px;
      font-size: 18px;
    }
    #shopify-section-{{ section.id }} .yg-param-box {
      margin-top: 24px;
    }
    #shopify-section-{{ section.id }} .yg-param-box .yg-param .yg-param-title{
      padding: 2px 8px;
      font-size: 18px;
      margin-bottom:4px;
    }
  }
  @media screen and (min-width: 769px) and (max-width: 1279px) {
    #shopify-section-{{ section.id }} .yg-info-box {
      padding-left: 36px;
      padding-right: 36px;
    }
    #shopify-section-{{ section.id }} .yg-content {
      margin-top: 12px;
      font-size: 16px;
    }
    #shopify-section-{{ section.id }} .yg-param-box {
      margin-top: 14px;
    }
    #shopify-section-{{ section.id }} .yg-param-box .yg-param .yg-param-title{
      font-size: 16px;
    }
    #shopify-section-{{ section.id }} .yg-param-box .yg-param .yg-param-content strong{
      font-size: 18px;
    }
    #shopify-section-{{ section.id }} .yg-item{
      margin-top: calc(var(--yg-mt) * 0.75);
      margin-bottom: calc(var(--yg-mb) * 0.75);
    }
    #shopify-section-{{ section.id }} {
      --yg-h2: 28px;
    }
  }
  @media screen and (min-width: 1280px) and (max-width: 1440px) {
    #shopify-section-{{ section.id }} .yg-param-box {
      margin-top: 14px;
    }
    #shopify-section-{{ section.id }} {
      --yg-h2: 32px;
    }
  }
</style>

{%- capture section_heading -%}
  {%- render 'section-heading', section: section -%}
{%- endcapture -%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    <div class="collage on-scroll{% if section_heading == blank %} without-heading{% endif %} grid items-center">
      {{- section_heading -}}

      <div class="yg-list">
        {%- for block in section.blocks -%}
          <div class="yg-item {% if block.settings.image_pos == 'right' %}yg-reverse{% endif %}" style="--yg-mt:{{ block.settings.item_margin_top }}px;--yg-mb:{{ block.settings.item_margin_bottom }}px;">
            {% liquid
              assign img = block.settings.image
              assign img_mobile = block.settings.image_mb | default: block.settings.image
              assign title = block.settings.title
              assign img_alt = title | strip_html
              assign content = block.settings.content
            %}
            {% if img != blank %}
            <div class="yg-image-box">
              {{ img | image_url: width: img.width | image_tag: loading: 'lazy', alt: img_alt, fetchpriority: 'low', class: 'yg-image hide-mobile' }}
              {{ img_mobile | image_url: width: img_mobile.width | image_tag: loading: 'lazy', alt: img_alt, fetchpriority: 'low', class: 'yg-image hide-pc' }}
            </div>
            {% endif %}

            <div class="yg-info-box">
              {% if title != blank %}
                <h2 class="yg-title">{{ title }}</h2>
              {% endif %}

              {% if content != blank %}
                <div class="yg-content">{{ content }}</div>
              {% endif %}

              <div class="yg-param-box">
                {% for i in (1..2)%}
                  {%- assign title_id = 'param_title_' | append: i -%}
                  {%- assign content_id = 'param_content_' | append: i -%}
                  {% if block.settings[title_id] != blank and block.settings[content_id] != blank %}
                    <div class="yg-param">
                      <p class="yg-param-title">{{ block.settings[title_id] }}</p>
                      <div class="yg-param-content">{{ block.settings[content_id] }}</div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "YG image with text list",
  "blocks": [
    {
      "type": "item",
      "name": "item",
      "settings": [
        {
          "type": "range",
          "id": "item_margin_top",
