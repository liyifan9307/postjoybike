          "id": "image_mb",
          "label": "Image(mobile)"
        },
        {
          "type": "select",
          "id": "image_pos",
          "label": "Image position",
          "options": [
            {
              "label": "Left",
              "value": "left"
            },
            {
              "label": "Right",
              "value": "right"
            },
          ],
          "default": "left"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "text",
          "id": "param_title_1",
          "label": "Param title-1"
        },
        {
          "type": "richtext",
          "id": "param_content_1",
          "label": "Param content-1"
        },

        {
          "type": "text",
          "id": "param_title_2",
          "label": "Param title-2"
        },
        {
          "type": "richtext",
          "id": "param_content_2",
          "label": "Param content-2"
        },
