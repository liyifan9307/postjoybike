<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}

    overflow: hidden;

  }
  #shopify-section-{{ section.id }} .media-card__content{
    position: absolute;
    bottom: 0;
    background: linear-gradient(0deg, #000 0%, rgba(0, 0, 0, 0.00) 100%);
    border-radius: var(--card-radius);
  }
  #shopify-section-{{ section.id }} .media-card .media{
    border-radius: var(--card-radius);
  }
  #shopify-section-{{ section.id }} .media-card__link .media img{
    aspect-ratio: unset;
  }
  #shopify-section-{{ section.id }} :is(h4,.h4){
    font-size: var(--text-h4);
    line-height: 1.4;
  }
  #shopify-section-{{ section.id }} .yg-heading{
    --heading-color:{{ section.settings.color_heading.rgb }};
    --heading-gradient:{{ section.settings.gradient_heading.rgb }};
    color: rgb(var(--heading-color));
    background-image: rgb(var(--heading-gradient));
  }

  #shopify-section-{{ section.id }}   .slider+:is(p,.indicators){
    justify-content: end;
  }
  #shopify-section-{{ section.id }}  .button:after{
    border-width: 1px;
  }

  #shopify-section-{{ section.id }}   .yg-swiper-btn{
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .swiper{
    overflow: visible;
  }
  #shopify-section-{{ section.id }} .swiper-button-next,
  #shopify-section-{{ section.id }} .swiper-button-prev{
    position: relative;
    display: block;
    top: 0;
    width:unset;
    height: unset;
    margin-top: 0;
    left:unset;
    right: unset;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar-drag {
    display: block;
    height: 6px;
    background-color: #FF9900;
  }
  #shopify-section-{{ section.id }} .swiper-button-next svg,
  #shopify-section-{{ section.id }} .swiper-button-prev svg{
    width: var(--sp-5d5);
    height: var(--sp-5d5);
  }
  #shopify-section-{{ section.id }}  .yg-indicator {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 32px;
    gap: 48px;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar.swiper-scrollbar-horizontal{
    position: relative;
    height: 6px;
    left: 0;
    bottom: 0;
    top: 0;
  }
  #shopify-section-{{ section.id }}   .media-card__text {
    --tw-translate-x: 0;
  }
  #shopify-section-{{ section.id }} .yg-no-swiper .swiper-wrapper{
    display: grid;
    grid-template-columns: repeat(3,1fr);
    --card-grid-gap: var(--sp-4);
    gap: var(--card-grid-gap);
  }
  #shopify-section-{{ section.id }} .yg-no-swiper .yg-indicator{
    display: none;
  }
  #shopify-section-{{ section.id }} .page-width{
    overflow: hidden;
  }
  @media screen and (max-width:768px){
    #shopify-section-{{ section.id }} .yg-no-swiper .swiper-wrapper{
      grid-template-columns: repeat(2,1fr);
      --card-grid-gap: 14px;
    }
  }
  @media screen and (max-width:640px){
    #shopify-section-{{ section.id }} .yg-no-swiper .swiper-wrapper{
      grid-template-columns: repeat(1,1fr);
    }
  }
</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- capture view_all -%}
      {%- if section.settings.show_view_all and section.blocks.size < collections.size -%}
        <a class="button button--secondary icon-with-text" href="{{ routes.collections_url }}" is="hover-link">
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">
            {%- liquid
              render 'icon', icon: 'newspaper'
              echo 'sections.collection_list.view_all' | t
            -%}
          </span>
        </a>
      {%- endif -%}
    {%- endcapture -%}
    {% comment %}
      {%- capture indicators -%}
        {%- if section.settings.carousel_on_desktop -%}
          <div class="indicators hidden lg:flex gap-2d5">
            <button class="button button--secondary" type="button" is="previous-button" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.previous' | t | escape }}" disabled>
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
              </span>
            </button>
            <button class="button button--secondary" type="button" is="next-button" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.next' | t | escape }}">
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
              </span>
            </button>
          </div>
          <p class="lg:hidden">{{ view_all }}</p>
        {%- else -%}
          <p>{{ view_all }}</p>
        {%- endif -%}
      {%- endcapture -%}
    {% endcomment %}
    {%- render 'section-heading', section: section -%}

    {% comment %}
      <slider-element
        id="Slider-{{ section.id }}"
        class="grid slider{% if section.settings.carousel_on_desktop %} slider--desktop{% endif %}{% if section.settings.swipe_on_mobile %} slider--tablet{% endif %}"
        selector=".card-grid>.card"
      >
    {% endcomment %}
    {% comment %} <motion-list class="card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid"> {% endcomment %}
    <yg-collections class="yg-collections">
      <div class="swiper">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            {%- render 'yg-collection-card',
              block: block,
              collection: collection,
              image_type: section.settings.image_type,
              image_ratio: section.settings.image_ratio,
              show_products_count: section.settings.show_products_count,
              position: forloop.index
            -%}
          {%- endfor -%}
        </div>
        <div class="yg-indicator indicators hidden lg:flex gap-2d5">
          <div class="swiper-scrollbar"></div>
          <div class="yg-swiper-btn">
            <div class="swiper-button-prev">
              <button class="button button--secondary" type="button" is="previous-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
                </span>
              </button>
            </div>
            <div class="swiper-button-next">
              <button class="button button--secondary" type="button" is="next-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
                </span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </yg-collections>
    {% comment %} </motion-list> {% endcomment %}

    {% comment %}
      {%- if section.settings.heading == blank
        and section.settings.subheading == blank
        and section.settings.description == blank
      -%}
        {%- if section.settings.carousel_on_desktop -%}
          <div class="indicators hidden lg:flex gap-2d5 items-center absolute top-0 left-0 w-full h-full pointer-events-none opacity-0 page-width">
            <button
              class="button button--primary pointer-events-auto"
              type="button"
              is="previous-button"
              aria-controls="Slider-{{ section.id }}"
              aria-label="{{ 'general.pagination.previous' | t | escape }}"
              disabled
              tabindex="-1"
            >
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'chevron-left', class: 'stroke-2 transform' -%}
              </span>
            </button>
            <button
              class="button button--primary pointer-events-auto"
              type="button"
              is="next-button"
              aria-controls="Slider-{{ section.id }}"
              aria-label="{{ 'general.pagination.next' | t | escape }}"
              tabindex="-1"
            >
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'chevron-right', class: 'stroke-2 transform' -%}
              </span>
            </button>
          </div>
        {%- endif -%}
      {%- endif -%}
    {% endcomment %}
    {% comment %} </slider-element> {% endcomment %}
    {% comment %} {{- indicators -}} {% endcomment %}
    {%- if section.settings.carousel_on_desktop -%}
      <p class="hidden lg:block">{{ view_all }}</p>
    {%- endif -%}
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    class YGCollections extends HTMLElement {
      constructor() {
        super();
        this.swiperInstance = null; // 存储 Swiper 实例
        this.handleResize = this.checkBreakpoint.bind(this); // 绑定 this 上下文
        this.isDesktop = null;
      }

      connectedCallback() {
        this.collectionsw();
        window.addEventListener('resize', this.handleResize);
      }

      disconnectedCallback() {
        // 组件移除时清理
        window.removeEventListener('resize', this.handleResize);
        this.destroySwiper();
      }

      destroySwiper() {
        if (this.swiperInstance) {
          this.swiperInstance.destroy(true); // 彻底销毁 Swiper
          this.swiperInstance = null;
          this.querySelector('.swiper')?.classList.remove('swiper-initialized', 'swiper-horizontal');
          this.querySelector('.swiper')?.classList.add('yg-no-swiper');
        }
      }
      checkBreakpoint() {
        const currentIsDesktop = window.innerWidth > 1024;

        // 状态未变化时直接返回
        if (this.isDesktop === currentIsDesktop) return;

        this.isDesktop = currentIsDesktop;

        if (currentIsDesktop) {
          this.collectionsw();
        } else {
          this.destroySwiper();
        }
      }
      collectionsw() {
        const $swiper = this.querySelector('.swiper');
        const $width = window.innerWidth;

        // 先销毁旧实例
        this.destroySwiper();

        if ($swiper && $width > 1024) {
          $swiper.classList.remove('yg-no-swiper');
          this.swiperInstance = new Swiper($swiper, {
            slidesPerView: 1.2,
            spaceBetween: 15,
            breakpoints: {
              390: {
                slidesPerView: 1.2,
                spaceBetween: 14,
              },
              1025: {
                slidesPerView: 3.1,
                spaceBetween: 24,
              },
            },
            scrollbar: {
              el: '.swiper-scrollbar',
              clickable: true,
            },
            navigation: {
              nextEl: '.swiper-button-next',
              prevEl: '.swiper-button-prev',
            },
          });
        } else {
          $swiper?.classList.add('yg-no-swiper');
        }
      }
    }

    if (!window.customElements.get('yg-collections')) {
      window.customElements.define('yg-collections', YGCollections);
    }
  });
</script>
