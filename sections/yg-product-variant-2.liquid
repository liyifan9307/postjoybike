<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
  @media(max-width: 768px) {
    #shopify-section-{{ section.id }} {
      --section-padding-top: calc({{ section.settings.padding_top_mobile | append: 'px' }} / 0.75);
      --section-padding-bottom: calc({{ section.settings.padding_bottom_mobile | append: 'px' }} / 0.75);
    }
  }

  #shopify-section-{{ section.id }} .yg-bg-image {
    position: absolute;
    z-index: 0;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .yg-bg-image img{
    width: 100%;
  }

  #shopify-section-{{ section.id }} .yg-product-container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: calc(50% - 20px) calc(50% - 20px);
    align-items: center;
    overflow: hidden;
    width: 100%;
    gap: 40px;
  }
  #shopify-section-{{ section.id }} .yg-product-left {
    width: 100%;
    aspect-ratio: var(--aspect-ratio-mobile);
  }
  #shopify-section-{{ section.id }} .yg-product-left .swiper-slide {
    opacity: 0 !important;
  }
  #shopify-section-{{ section.id }} .yg-product-left .swiper-slide-active {
    opacity: 1 !important;
  }

  #shopify-section-{{ section.id }} .yg-product-right .yg-content {
    max-width: 500px;
    margin-inline: auto;
    text-align: center;
    font-size: 44px;
  }

  #shopify-section-{{ section.id }} .yg-product-right .yg-content strong {
    color: #F90;
  }

  #shopify-section-{{ section.id }} .yg-product-right .yg-content .yg-cont {
    margin-top: 12px;
    font-size: 20px;
    color: #575553;
  }

  #shopify-section-{{ section.id }} .yg-color-variants {
    margin-top: 32px;
  }

  #shopify-section-{{ section.id }} .yg-variant-bg {
    display: inline-block;
    min-width: 32px;
    height: 32px;
    border-radius: 50%;
  }

  #shopify-section-{{ section.id }} .yg-color-variants .swiper-wrapper {
    width: fit-content;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .yg-color-variants .swiper-slide {
    padding: 8px 16px 8px 8px;
    width: auto;
    max-width: 48px;
    padding-right: 0;
    border-radius: 50px;
    cursor: pointer;
    overflow: hidden;
    transition: max-width 0.3s, padding-right 0.3s;
  }

  #shopify-section-{{ section.id }} .yg-color-variants .yg-variant-color {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .yg-color-variants .swiper-slide.swiper-slide-thumb-active {
    box-shadow: inset 0px 0px 0px 2px  #000000;
    max-width: 130px;
    padding-right: 16px;
  }

  @media(max-width: 550px) {
    #shopify-section-{{ section.id }} .yg-product-container {
      grid-template-columns: 100%;
      gap: 24px;
    }

    #shopify-section-{{ section.id }} .yg-product-left {
      aspect-ratio: var(--aspect-ratio-mobile);
    }

    #shopify-section-{{ section.id }} .yg-color-variants .swiper-slide {
      box-shadow: inset 0px 0px 0px 2px  #C7C6C5;
      max-width: 130px;
      padding-right: 16px;
    }
  }
</style>

{%- capture section_heading -%}
  {%- render 'section-heading', section: section -%}
{%- endcapture -%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %}{% if section_heading == blank %} page-width--narrow{% endif %} relative">
    <yg-product-variant-2 class="yg-product-variant">
      {%- if section.settings.bg_image != blank -%}
        <div class="yg-bg-image">
          {{
            section.settings.bg_image
            | image_url: width: section.settings.bg_image.width
            | image_tag: loading: 'lazy'
          }}
        </div>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="yg-product-container">
          {% assign aspect_ratio = section.blocks[0].settings.image.aspect_ratio %}
          <div class="yg-product-left swiper" style="--aspect-ratio-mobile: {{ aspect_ratio }}">
            <div class="swiper-wrapper">
              {%- for block in section.blocks -%}
                {% if block.settings.color != blank and block.settings.image != blank %}
                  <div class="swiper-slide">
                    {{
                      block.settings.image
                      | image_url: width: block.settings.image.width
                      | image_tag: loading: 'lazy', class: 'yg-variant-image'
                    }}
                  </div>
                {% endif %}
              {%- endfor -%}
            </div>
          </div>
          <div class="yg-product-right">
            <div class="yg-content">
              <h2 class="{{ section.settings.title_size }}">
                {{ section.settings.title | default: section.settings.product.title }}
              </h2>
              <div class="yg-cont">
                {{
                  section.settings.content
                  | default: section.settings.product.metafields.custom.product_description.value
                }}
              </div>
            </div>
            <div class="yg-color-variants swiper">
              <div class="swiper-wrapper">
                {%- for block in section.blocks -%}
                  {% if block.settings.color != blank and block.settings.image != blank %}
                    <div class="swiper-slide">
                      <div class="yg-variant-color">
                        <div class="yg-variant-bg" style="background-color:{{ block.settings.color }};"></div>
                        <span>{{ block.settings.color_label | default: 'color' }}</span>
                      </div>
                    </div>
                  {% endif %}
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </yg-product-variant-2>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    class YGProductVariant2 extends HTMLElement {
      get variantColors() {
        let $variantColors = this.querySelector('.yg-color-variants');
        let variantColors = new Swiper($variantColors, {
          spaceBetween: 10,
          slidesPerView: 'auto',
          freeMode: true,
          watchSlidesProgress: true,
        });

        return variantColors;
      }

      get variantImages() {
        let $variantImages = this.querySelector('.yg-product-left');
        let variantImages = new Swiper($variantImages, {
          direction: 'vertical',
          spaceBetween: 0,
          effect: 'fade',
          mousewheel: true,
          thumbs: {
            swiper: this.variantColors,
          },
        });

        return variantImages;
      }

      constructor() {
        super();
      }
      connectedCallback() {
        let swiperImage = this.variantImages();
        if (window.innerWidth < 550) {
          swiperImage.mousewheel.enable();
        } else {
          swiperImage.mousewheel.disable();
        }
        window.addEventListener('resize', () => {
          if (window.innerWidth < 550) {
            swiperImage.mousewheel.enable();
            swiperImage.changeDirection();
          } else {
            swiperImage.mousewheel.disable();
          }
        });
      }
    }
    if (!window.customElements.get('yg-product-variant-2')) {
      window.customElements.define('yg-product-variant-2', YGProductVariant2);
    }
  });
</script>

