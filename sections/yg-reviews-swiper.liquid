<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
  #shopify-section-{{ section.id }}  .swiper{
    overflow: unset;
    user-select: none;
  }
  #shopify-section-{{ section.id }} .yg-reviews-slide-button {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    transition: all ease-in-out 0.3s;
    transform: translate(-50%, -50%);
  }
  #shopify-section-{{ section.id }}  .yg-indicator {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20px;
    gap: 48px;
  }
  #shopify-section-{{ section.id }} .yg-reviews-slide-button:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }
  #shopify-section-{{ section.id }} .yg-review-block__open {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .swiper-scrollbar-drag{
        background: #C9B09A;
  }
  #shopify-section-{{ section.id }}  .yg-review-block__image:before{
    position: absolute;
    content: "";
    width: 100%;
    height: 100%;
    z-index: 1;
    background:rgb(var(--content-over-media-overlay));
  }
  #shopify-section-{{ section.id }} .yg-review-block__image {
      position: relative;
      z-index: 1;
      height:auto;
      width:auto;
      display: flex;
      overflow: hidden;
      border-radius: 16px;
  }

  #shopify-section-{{ section.id }} .yg-review-block__image .yg-image {
    transition: transform 0.3s ease-in-out;
  }

  #shopify-section-{{ section.id }} .yg-review-block__image:hover .yg-image {
    transform: scale(1.05);
  }

  #shopify-section-{{ section.id }} .yg-content-date{
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ section.id }} .yg-content-date .text-base{
    font-weight: 600;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar-drag {
    display: block;
    height: 4px;
    background-color: #FF9900;
  }
  .swiper-button-prev:after,
  .swiper-button-next:after{
    content: unset;
  }
  #shopify-section-{{ section.id }} .yg-review-block{
    overflow: hidden;
    border-radius: {{section.settings.yg_border_radius}}px;
  }
  #shopify-section-{{ section.id }} .yg-image{
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .yg-review-block__open svg {
    transition: transform .3s;
  }
  #shopify-section-{{ section.id }} .yg-review-block__open:hover svg {
    transform: scale(1.05);
  }
  #shopify-section-{{ section.id }} .yg-review-block__content {
    background: var(--card-background);
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: space-between;
  }
  #shopify-section-{{ section.id }} .yg-reviews-star{
    display: flex;
    flex-direction: row;
  }
  #shopify-section-{{ section.id }} .floating-controls-container{
    margin-top: 32px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .yg-review-block__user {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }
  #shopify-section-{{ section.id }} .swiper-horizontal{
    padding: 0 0 3rem 0;
  }
  #shopify-section-{{ section.id }} .yg-review-block__user .yg-review-block__user-image {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar.swiper-scrollbar-horizontal{
    position: relative;
    height: 4px;
    left: 0;
    bottom: 0;
    top: 0;
  }
  #shopify-section-{{ section.id }} .yg-review-block__dialog {
    width: min(100%, 1200px);
    border: none;
    border-color: transparent;
    background: transparent;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }}   .yg-swiper-btn{
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .yg-review-block__dialog iframe {
    width: 100%;
    aspect-ratio: 16/9;
    border:none;
  }
  #shopify-section-{{ section.id }} .swiper-button-next,
  #shopify-section-{{ section.id }} .swiper-button-prev{
    position: relative;
    display: block;
    top: 0;
    width:unset;
    height: unset;
    margin-top: 0;
    left:unset;
    right: unset;
  }
  #shopify-section-{{ section.id }} .yg-reviews__block-score{
    margin-top: 12px;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar-drag {
    display: block;
    height: 6px;
    background-color: #FF9900;
  }
  #shopify-section-{{ section.id }} .swiper-button-next svg,
  #shopify-section-{{ section.id }} .swiper-button-prev svg{
    width: var(--sp-5d5);
    height: var(--sp-5d5);
  }
  #shopify-section-{{ section.id }}  .yg-indicator {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 32px;
    gap: 48px;
  }
  #shopify-section-{{ section.id }}  .swiper-scrollbar.swiper-scrollbar-horizontal{
    position: relative;
    height: 6px;
    left: 0;
    bottom: 0;
    top: 0;
  }

    @media screen and (max-width:749px) {
        #shopify-section-{{ section.id }} .yg-review-block__content {
        padding:14px;
        gap: 6px;
      }
    }
</style>

{%- capture section_heading -%}
  {%- render 'section-heading', section: section -%}
{%- endcapture -%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %}{% if section_heading == blank %} page-width--narrow{% endif %} relative">
    <div class="collage on-scroll{% if section_heading == blank %} without-heading{% endif %} grid items-center">
      {{- section_heading -}}
    </div>

    <div class="floating-controls-container">
      <yg-video-reviews-comment
        class="yg-video-reviews swiper swiper-style1"
      >
        <div class="swiper-wrapper" data-block-size="{{ section.blocks .size}}">
          {% for block in section.blocks %}
            <div class="yg-review-block swiper-slide">
              <div
                class="yg-review-block__image "
                style="--content-over-media-overlay: {{ block.settings.yg_overlay.rgb }} / {{ block.settings.yg_image_mask | divided_by: 100.0 }}"
              >
                {% assign img = block.settings.image %}
                {% assign youtube_poster = 'https://img.youtube.com/vi/'
                  | append: block.settings.video_url.id
                  | append: '/mqdefault.jpg'
                %}
                {% if img != blank %}
                  {{-
                    img
                    | image_url: width: img.width
                    | image_tag:
                      class: 'yg-image',
                      alt: img.alt,
                      preload: 'lazy',
                      widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200'
                  -}}
                {% elsif block.settings.video_url != blank %}
                  <img src="{{ youtube_poster }}" alt="{{ desc }}" width="100%" height="auto" class="yg-image">
                {% else %}
                  {%- capture placeholder_image -%}{% cycle 'placeholder': 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
                  {{-
                    placeholder_image
                    | placeholder_svg_tag: 'placeholder'
                    | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"'
                  -}}
                {% endif -%}
                {%- if block.settings.video != blank or block.settings.video_url != blank %}
                  <yg-open-popup class="yg-reviews-slide-button">
                    <button type="button">
                      <span class="sr-only">{{ 'general.accessibility.play_video' | t }}</span>
                      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64" fill="none">
                        <foreignObject x="4" y="4" width="56" height="56">
                          <div xmlns="http://www.w3.org/1999/xhtml"
                               style="backdrop-filter:blur(2px);clip-path:url(#bgblur_0_23_1167_clip_path);height:100%;width:100%"></div>
                        </foreignObject>
                        <path data-figma-bg-blur-radius="4"
                              d="M32 56C18.7452 56 8 45.2547 8 32C8 18.7452 18.7452 8 32 8C45.2547 8 56 18.7452 56 32C56 45.2547 45.2547 56 32 56Z"
                              fill="#282731" fill-opacity="0.4"/>
                        <path
                          d="M27.0565 23C27.2652 23 27.4691 23.0624 27.6426 23.1793L40.5294 31.8616C41.0149 32.1886 41.1462 32.8516 40.8223 33.3422C40.745 33.4594 40.6454 33.56 40.5294 33.6383L27.6426 42.3205C27.1572 42.6477 26.5011 42.5151 26.1775 42.0244C26.0618 41.8491 26 41.643 26 41.4321V24.0677C26 23.478 26.4731 23 27.0565 23Z"
                          fill="white"/>
                        <defs>
                          <clipPath id="bgblur_0_23_1167_clip_path" transform="translate(-4 -4)">
                            <path
                              d="M32 56C18.7452 56 8 45.2547 8 32C8 18.7452 18.7452 8 32 8C45.2547 8 56 18.7452 56 32C56 45.2547 45.2547 56 32 56Z"/>
                          </clipPath>
                        </defs>
                      </svg>
                    </button>
                    <template>
                      {%- if block.settings.video != blank -%}
                        {{-
                          block.settings.video
                          | video_tag:
                            playsinline: true,
                            preload: 'metadata',
                            autoplay: true,
                            muted: true,
                            loop: true,
                            controls: true,
                            image_size: '100%'
                        -}}
                      {% else %}
                        {%- if block.settings.video_url.type == 'youtube' -%}
                          <iframe
                            src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?playsinline=1&autoplay=1&controls=0&mute=0&loop=1&playlist={{ block.settings.video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}"
                            allow="autoplay; encrypted-media"
                            allowfullscreen="allowfullscreen"
                          ></iframe>
                        {%- elsif block.settings.video_url.type == 'vimeo' -%}
                          <iframe
                            src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autopause=1&}background=1&autoplay=1&loop=1&muted=0&transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.text_color | remove_first: '#' }}"
                            allow="autoplay; encrypted-media;"
                            allowfullscreen="allowfullscreen"
                          ></iframe>
                        {%- endif -%}
                      {%- endif -%}
                    </template>
                  </yg-open-popup>
                {% endif %}
              </div>
              {% if block.settings.rating > 0
                or block.settings.title != blank
                or block.settings.content != blank
                or block.settings.yg_show_image
              %}
                <div class="yg-review-block__content" style="--card-background:{{ block.settings.card_background }} ;">
                  {% assign rating = block.settings.rating %}
                  {% if rating > 0 %}
                    <div class="yg-reviews__block-score text-xl bold">
                      <div class="yg-reviews__block-score text-xl bold">
                        {% comment %} {{ block.settings.rating | divided_by: 1.0 }} {% endcomment %}
                        {%- if block.settings.rating != blank %}
                          <div class="yg-reviews-star">
                            {% liquid
                              assign rating = block.settings.rating | plus: 0
                              assign rounded_rating = rating | floor
                              assign remaining_rating = rating | minus: rounded_rating | times: 100
                            %}
                            {% for i in (1..rounded_rating) %}
                              <span class="yg-star">
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  width="20"
                                  height="20"
                                  viewBox="0 0 14 13"
                                  fill="none"
                                >
                                  <path d="M6.99957 0.166748L4.96191 4.32595L0.333374 4.99712L3.68634 8.27512L2.88484 12.8334L6.99957 10.6398L11.1152 12.8334L10.3196 8.27512L13.6667 4.99712L9.06381 4.32595L6.99957 0.166748Z"
                                      fill="{{block.settings.yg_rating_color}}"/>
                                </svg>
                              </span>
                              {%- assign mask_rect_id = 'mask' | append: i -%}
                            {% endfor %}
                            {%- if remaining_rating > 0 -%}
                              <span class="yg-star">
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  width="20"
                                  height="20"
                                  viewBox="0 0 14 13"
                                  fill="none"
                                >
                                  <defs>
                                      <mask id={{ mask_rect_id }}>
                                      <rect x="0" y="0" width="{{ remaining_rating }}%" height="100%"
                                              fill="#fff"/>
                                      </mask>
                                  </defs>

                                  <path d="M6.99957 0.166748L4.96191 4.32595L0.333374 4.99712L3.68634 8.27512L2.88484 12.8334L6.99957 10.6398L11.1152 12.8334L10.3196 8.27512L13.6667 4.99712L9.06381 4.32595L6.99957 0.166748Z"
                                          fill="{{block.settings.yg_rating_color}}" mask="url(#{{ mask_rect_id }})"/>
                                </svg>
                              </span>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  {% endif %}
                  {%- if block.settings.title -%}
                    <div class="text-base h6">{{ block.settings.title }}</div>
                  {%- endif -%}
                  {%- if block.settings.content -%}
                    <div class="text-base">{{ block.settings.content }}</div>
                  {%- endif -%}
                  {% if block.settings.yg_show_image %}
                    <div class="yg-review-block__user">
                      {% assign img = block.settings.user_image | default: block.settings.image %}
                      {% if img != blank %}
                        <div class="yg-review-block__user-image">
                          {{-
                            img
                            | image_url: width: img.width
                            | image_tag:
                              class: 'yg-image',
                              alt: img.alt,
                              preload: 'lazy',
                              widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200'
                          -}}
                        </div>
                      {% endif %}
                      <div class="yg-content-date">
                        {% if block.settings.user != blank %}
                          <span class="text-base">{{ block.settings.user }}</span>
                        {% endif %}
                        {% if block.settings.user != blank %}
                          <span>{{ block.settings.time }}</span>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
        <div class="yg-indicator indicators hidden lg:flex gap-2d5">
          <div class="swiper-scrollbar"></div>
          <div class="yg-swiper-btn">
            <div class="swiper-button-prev">
              <button class="button button--secondary" type="button" is="previous-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
                </span>
              </button>
            </div>
            <div class="swiper-button-next">
              <button class="button button--secondary" type="button" is="next-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
                </span>
              </button>
            </div>
          </div>
        </div>
      </yg-video-reviews-comment>
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    class YGReviews extends HTMLElement {
      constructor() {
        super();
        this.init();
      }
      init() {
        this.swiperStyle1();
      }
      swiperStyle1() {
        let swiper = this;
        const $size = swiper.querySelector('.swiper-wrapper').dataset.blockSize;
        let $count = 0;
        if ($size > 3) {
          $count = 3;
        } else {
          $count = $size;
        }
        new Swiper(swiper, {
          slidesPerView: 1.2,
          spaceBetween: 15,
          breakpoints: {
            390: {
              slidesPerView: 1.2,
              spaceBetween: 14,
            },
            1000: {
              slidesPerView: $count,
              spaceBetween: 24,
            },
          },
          scrollbar: {
            el: '.swiper-scrollbar',
            clickable: true,
          },
          navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
          },
          on: {
            init: function () {
              const totalSlides = this.slides.length;
              const needsNavigation = totalSlides > this.params.slidesPerView;
              // this.navigation.nextEl.addEventListener('click', (e) => e.stopPropagation());
              // this.navigation.prevEl.addEventListener('click', (e) => e.stopPropagation());
              this.navigation.nextEl.style.display = needsNavigation ? 'flex' : 'none';
              this.navigation.prevEl.style.display = needsNavigation ? 'flex' : 'none';
            },
            // 在窗口大小变化时更新
            resize: function () {
              this.update();
              const totalSlides = this.slides.length;
              const needsNavigation = totalSlides > this.params.slidesPerView;
              this.navigation.nextEl.style.display = needsNavigation ? 'flex' : 'none';
              this.navigation.prevEl.style.display = needsNavigation ? 'flex' : 'none';
            },
          },
        });
      }
    }
    if (!window.customElements.get('yg-video-reviews-comment')) {
      window.customElements.define('yg-video-reviews-comment', YGReviews);
    }
  });
</script>
{% schema %}
