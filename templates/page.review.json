      "settings": {
        "liquid": "<style>\n/* ===== Tabs ===== */\n.tab-buttons {\n  display: flex;\n  gap: 40px;\n  border-bottom: 1px solid #ddd;\n  margin-bottom: 30px;\n  font-size: 20px;\n  font-weight: 600;\n}\n\n.tab-buttons button {\n  background: none;\n  border: none;\n  padding: 15px 0;\n  cursor: pointer;\n  color: #333;\n}\n\n.tab-buttons button.active {\n  color: red;\n  border-bottom: 3px solid red;\n}\n\n.tab-content {\n  display: none;\n}\n\n.tab-content.active {\n  display: block;\n}\n\n/* ===== 视频网格 ===== */\n.video-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 20px;\n}\n\n.video-card iframe {\n  width: 100%;\n  aspect-ratio: 16 / 9;\n  border-radius: 12px;\n  border: none;\n}\n\n/* 平板 */\n@media (max-width: 1024px) {\n  .video-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n/* 手机 */\n@media (max-width: 768px) {\n  .video-grid {\n    grid-template-columns: 1fr;\n  }\n}\n</style>\n\n<!-- ===== Tabs Buttons ===== -->\n<div class=\"tab-buttons\">\n  <button class=\"active\" onclick=\"openTab(event, 'video')\">\n    Video Reviews\n  </button>\n  <button onclick=\"openTab(event, 'customer')\">\n    Customer Reviews\n  </button>\n</div>\n\n<!-- ===== Video Tab ===== -->\n<div id=\"video\" class=\"tab-content active\">\n\n  <div class=\"video-grid\">\n\n    <div class=\"video-card\">\n      <iframe src=\"https://www.youtube.com/embed/KBNlmP6tsso\" allowfullscreen></iframe>\n    </div>\n\n    <div class=\"video-card\">\n      <iframe src=\"https://www.youtube.com/embed/gtPspd2ARKI\" allowfullscreen></iframe>\n    </div>\n\n    <div class=\"video-card\">\n      <iframe src=\"https://www.youtube.com/embed/w3qjDWvGmkA\" allowfullscreen></iframe>\n    </div>\n\n    <div class=\"video-card\">\n      <iframe src=\"https://www.youtube.com/embed/h2p3CdFti3g\" allowfullscreen></iframe>\n    </div>\n\n    <div class=\"video-card\">\n      <iframe src=\"https://www.youtube.com/embed/RatUeCqqePM\" allowfullscreen></iframe>\n    </div>\n\n    <div class=\"video-card\">\n      <iframe src=\"https://www.youtube.com/embed/4t-3FfnACNo\" allowfullscreen></iframe>\n    </div>\n\n    <div class=\"video-card\">\n      <iframe src=\"https://www.youtube.com/embed/Uv78hZi1aHY\" allowfullscreen></iframe>\n    </div>\n\n  </div>\n\n</div>\n\n<!-- ===== Customer Reviews Tab ===== -->\n<div id=\"customer\" class=\"tab-content\">\n  <div class=\"jdgm-widget\" data-type=\"all_reviews\"></div>\n</div>\n\n<script>\nfunction openTab(evt, tabName) {\n  var tabcontent = document.querySelectorAll(\".tab-content\");\n  tabcontent.forEach(el => el.classList.remove(\"active\"));\n\n  var tabbuttons = document.querySelectorAll(\".tab-buttons button\");\n  tabbuttons.forEach(btn => btn.classList.remove(\"active\"));\n\n  document.getElementById(tabName).classList.add(\"active\");\n  evt.currentTarget.classList.add(\"active\");\n\n  /* 强制刷新 Judge.me，解决隐藏导致空白问题 */\n  if(tabName === \"customer\"){\n    setTimeout(function(){\n      if(window.jdgm && jdgm.reloadWidgets){\n        jdgm.reloadWidgets();\n      }\n    }, 300);\n  }\n}\n</script>",
