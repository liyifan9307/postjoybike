        "color_background": "",
        "gradient_background": "",
        "color_highlight": "",
        "gradient_highlight": "",
        "color_button_text": "",
        "color_button_background": "",
        "color_button_gradient": "",
        "padding_top": 72,
        "padding_bottom": 0,
        "divider": false,
        "full_width": false,
        "rounded": false,
        "enable_parallax": true
      }
    },
