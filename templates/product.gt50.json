      "blocks": {
        "question_m63DGa": {
          "type": "question",
          "settings": {
            "title": "Q: Why does the controller say 48V when the GT50 has a 60V battery?",
            "text": "<p>A: The “48V” marking is a standard label on the controller housing. Internally, the GT50 uses a wide-voltage smart ECU system that supports 48V–60V input, so it is fully compatible with the included 60V 30Ah battery.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_MkHaiq": {
          "type": "question",
          "settings": {
            "title": "Q: Why does the tire show 16 instead of 20?",
            "text": "<p>A: The “16” on the tire sidewall refers to motorcycle-style rim diameter, while the product page lists the tire’s approximate outer size as 20\" x 3.0\". These are two different tire measurement standards.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_cdPqg7": {
          "type": "question",
          "settings": {
            "title": "Q: Are the GT50 tires suitable for off-road riding?",
            "text": "<p>A: Yes. The GT50 uses wide 20\" x 3.0\" motorcycle-style off-road tires with aggressive tread, suitable for gravel, dirt trails, mountain roads, rural roads, mud, snow, and pavement.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_dhWDg8": {
          "type": "question",
          "settings": {
            "title": "Q: What is the top speed of the GT50?",
            "text": "<p>A: The GT50 can reach up to 40 MPH under suitable conditions. Actual speed may vary depending on rider weight, terrain, battery level, tire pressure, and riding mode.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_Px9kFn": {
          "type": "question",
          "settings": {
            "title": "Q: How far can the GT50 go on one charge?",
            "text": "<p>A: The GT50 offers up to 80 miles of range. Actual range depends on speed, rider weight, road conditions, throttle usage, assist level, and weather.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_KmXnGX": {
          "type": "question",
          "settings": {
            "title": "Q: How long does it take to charge the GT50?",
            "text": "<p>A: The GT50 battery usually takes around 6–8 hours to fully charge.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_w7j7p6": {
          "type": "question",
          "settings": {
            "title": "Q: What brakes does the GT50 use?",
            "text": "<p>A: The GT50 comes with hydraulic disc brakes, offering responsive and reliable stopping power for high-speed riding, downhill sections, and emergency braking.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_VnAdR7": {
          "type": "question",
          "settings": {
            "title": "Q: What is the maximum load capacity?",
            "text": "<p>A: The GT50 supports up to 365 lbs of maximum payload capacity.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
