    "custom_liquid_JaLkd8": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "liquid": "<style>\n  .pj-wrap *{box-sizing:border-box;margin:0;padding:0}\n  .pj-wrap{font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Inter,Roboto,sans-serif;color:#0F172A;line-height:1.6;max-width:1200px;margin:0 auto}\n  .pj-hero{background:linear-gradient(135deg,#0F172A 0%,#1E293B 100%);color:#fff;padding:60px 30px;text-align:center;border-radius:12px;margin-bottom:40px;position:relative;overflow:hidden}\n  .pj-hero::before{content:\"\";position:absolute;top:-50%;right:-10%;width:400px;height:400px;background:radial-gradient(circle,#FF6B35 0%,transparent 70%);opacity:.3}\n  .pj-badge{display:inline-block;background:#FF6B35;color:#fff !important;padding:6px 16px;border-radius:20px;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:20px;position:relative;z-index:1}\n  .pj-hero h1{font-size:42px;font-weight:800;margin-bottom:16px;position:relative;z-index:1;letter-spacing:-.5px;color:#FFD60A !important;text-shadow:0 2px 8px rgba(0,0,0,.35)}\n  .pj-hero p{font-size:18px;color:#F1F5F9 !important;opacity:.95;max-width:720px;margin:0 auto;position:relative;z-index:1}\n  .pj-section{padding:50px 30px;border-bottom:1px solid #E2E8F0}\n  .pj-section h2{font-size:32px;font-weight:800;margin-bottom:24px;color:#0F172A !important;letter-spacing:-.5px}\n  .pj-section h2 span{color:#FF6B35 !important}\n  .pj-section p{font-size:16px;color:#475569;margin-bottom:16px}\n  .pj-features{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;margin-top:30px}\n  .pj-feature{background:#F8FAFC;padding:28px 22px;border-radius:12px;border-left:4px solid #FF6B35;transition:transform .2s}\n  .pj-feature:hover{transform:translateY(-4px)}\n  .pj-feature .pj-icon{width:48px;height:48px;background:#FF6B35;color:#fff;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:800;margin-bottom:14px}\n  .pj-feature h3{font-size:17px;font-weight:700;margin-bottom:8px;color:#0F172A}\n  .pj-feature p{font-size:14px;color:#64748B;margin:0}\n  .pj-color-options{display:flex;gap:18px;flex-wrap:wrap;justify-content:center;margin-top:30px}\n  .pj-color-card{background:#fff;border:2px solid #E2E8F0;padding:20px 24px;border-radius:12px;text-align:center;min-width:140px;transition:all .2s}\n  .pj-color-card:hover{border-color:#FF6B35;transform:translateY(-3px)}\n  .pj-color-swatch{width:60px;height:60px;border-radius:50%;margin:0 auto 12px;border:3px solid #fff;box-shadow:0 0 0 2px #E2E8F0}\n  .pj-color-card span{font-weight:700;color:#0F172A;font-size:15px}\n  .pj-highlight-box{background:linear-gradient(135deg,#FFF7ED 0%,#FED7AA 100%);padding:36px;border-radius:12px;margin-top:24px;border:1px solid #FFB800}\n  .pj-highlight-box h2{margin-bottom:14px}\n  .pj-highlight-list{list-style:none;display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:12px;margin-top:20px}\n  .pj-highlight-list li{padding-left:30px;position:relative;font-size:15px;color:#0F172A;font-weight:500;padding-top:4px;padding-bottom:4px}\n  .pj-highlight-list li::before{content:\"✓\";position:absolute;left:0;top:2px;width:22px;height:22px;background:#FF6B35;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800}\n  .pj-spec-table{width:100%;border-collapse:collapse;margin-top:20px;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(15,23,42,.08)}\n  .pj-spec-table th,.pj-spec-table td{padding:16px 20px;text-align:left;border-bottom:1px solid #E2E8F0;font-size:15px}\n  .pj-spec-table th{background:#0F172A;color:#fff !important;font-weight:700;width:40%}\n  .pj-spec-table tr:last-child td{border-bottom:none}\n  .pj-spec-table tr:nth-child(even) td{background:#F8FAFC}\n  .pj-faq-item{background:#F8FAFC;border-radius:10px;padding:22px 26px;margin-bottom:14px;border-left:4px solid #0F172A;transition:border-color .2s}\n  .pj-faq-item:hover{border-left-color:#FF6B35}\n  .pj-faq-item h3{font-size:17px;font-weight:700;margin-bottom:10px;color:#0F172A;display:flex;align-items:flex-start;gap:10px}\n  .pj-faq-item h3::before{content:\"Q\";background:#FF6B35;color:#fff;width:26px;height:26px;border-radius:6px;display:inline-flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}\n  .pj-faq-item p{font-size:15px;color:#475569;margin:0;padding-left:36px}\n  .pj-cta{background:#0F172A;color:#fff;text-align:center;padding:50px 30px;border-radius:12px;margin-top:40px}\n  .pj-cta h2{color:#FFD60A !important;margin-bottom:14px;text-shadow:0 2px 8px rgba(0,0,0,.35)}\n  .pj-cta p{color:#CBD5E1 !important;font-size:17px;margin-bottom:0}\n  @media(max-width:640px){.pj-hero h1{font-size:30px}.pj-hero p{font-size:15px}.pj-section{padding:36px 20px}.pj-section h2{font-size:24px}.pj-spec-table th,.pj-spec-table td{padding:12px 14px;font-size:14px}}\n</style>\n\n<div class=\"pj-wrap\">\n\n  <div class=\"pj-hero\">\n    <span class=\"pj-badge\">Cycling Accessories</span>\n    <h1>PostJoy Cooling Arm Sleeves</h1>\n    <p>Stay cool, stay protected. Lightweight cycling sleeves designed for sunny rides — comfortable summer protection that pairs with any outfit.</p>\n  </div>\n\n  <div class=\"pj-section\">\n    <h2>Cool Comfort for <span>Sunny Rides</span></h2>\n    <p>Ride cooler and more comfortably with PostJoy Cooling Arm Sleeves. Designed for cycling, commuting, outdoor sports, and warm-weather riding, these sleeves are a simple but useful accessory for riders who spend time under the sun.</p>\n    <p>The lightweight design makes them easy to wear during long rides, while the flexible fit helps them stay comfortable as you move. Available in Black, Gray, and White, they pair easily with different riding outfits and eBike styles.</p>\n  </div>\n\n  <div class=\"pj-section\">\n    <h2>Choose Your <span>Color</span></h2>\n    <div class=\"pj-color-options\">\n      <div class=\"pj-color-card\"><div class=\"pj-color-swatch\" style=\"background:#0F172A\"></div><span>Black</span></div>\n      <div class=\"pj-color-card\"><div class=\"pj-color-swatch\" style=\"background:#94A3B8\"></div><span>Gray</span></div>\n      <div class=\"pj-color-card\"><div class=\"pj-color-swatch\" style=\"background:#F8FAFC;border-color:#E2E8F0\"></div><span>White</span></div>\n    </div>\n  </div>\n\n  <div class=\"pj-section\">\n    <h2>Key <span>Features</span></h2>\n    <div class=\"pj-features\">\n      <div class=\"pj-feature\"><div class=\"pj-icon\">☀️</div><h3>Sun Protection</h3><p>Helps shield arms from direct sunlight during long rides.</p></div>\n      <div class=\"pj-feature\"><div class=\"pj-icon\">🌬️</div><h3>Lightweight & Cool</h3><p>Breathable fabric keeps you comfortable in warm weather.</p></div>\n      <div class=\"pj-feature\"><div class=\"pj-icon\">🏃</div><h3>Multi-Sport Use</h3><p>Cycling, running, hiking, driving, fishing, and more.</p></div>\n      <div class=\"pj-feature\"><div class=\"pj-icon\">🔄</div><h3>Flexible Fit</h3><p>Stays comfortably in place as you move.</p></div>\n      <div class=\"pj-feature\"><div class=\"pj-icon\">🎨</div><h3>3 Classic Colors</h3><p>Black, Gray, and White to match every outfit.</p></div>\n    </div>\n  </div>\n\n  <div class=\"pj-section\">\n    <div class=\"pj-highlight-box\">\n      <h2>Why You'll <span>Love Them</span></h2>\n      <p>These cooling arm sleeves are a practical summer riding essential. They help reduce direct sun exposure while keeping your arms covered without the need for a full long-sleeve shirt.</p>\n      <ul class=\"pj-highlight-list\">\n        <li>Great for summer cycling</li>\n        <li>Comfortable and breathable wearing experience</li>\n        <li>Easy to put on and remove</li>\n        <li>Lightweight design for daily use</li>\n        <li>Available in three classic colors</li>\n      </ul>\n    </div>\n  </div>\n\n  <div class=\"pj-section\">\n    <h2>Product <span>Specifications</span></h2>\n    <table class=\"pj-spec-table\">\n      <tr><th>Product Name</th><td>PostJoy Cooling Arm Sleeves</td></tr>\n      <tr><th>Category</th><td>Cycling Accessories</td></tr>\n      <tr><th>Colors</th><td>Black, Gray, White</td></tr>\n      <tr><th>Use Case</th><td>Cycling, commuting, outdoor sports</td></tr>\n      <tr><th>Fit</th><td>Flexible fit</td></tr>\n    </table>\n  </div>\n\n  <div class=\"pj-section\">\n    <h2>Frequently Asked <span>Questions</span></h2>\n    <div class=\"pj-faq-item\"><h3>What colors are available?</h3><p>The PostJoy Cooling Arm Sleeves are available in Black, Gray, and White.</p></div>\n    <div class=\"pj-faq-item\"><h3>Are these only for cycling?</h3><p>No. They are suitable for cycling, commuting, running, hiking, driving, fishing, and other outdoor activities.</p></div>\n    <div class=\"pj-faq-item\"><h3>Are they suitable for summer riding?</h3><p>Yes. They are designed for warm-weather use and help keep your arms covered during sunny rides.</p></div>\n  </div>\n\n  <div class=\"pj-cta\">\n    <h2>Beat the Heat. Keep the Joy.</h2>\n    <p>Stay protected and comfortable on every sunny ride with PostJoy.</p>\n  </div>\n\n</div>",
