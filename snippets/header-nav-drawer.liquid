{%- liquid
  assign section_rendering_api = false
  if section.index == nil
    assign section_rendering_api = true
  endif
-%}
<details is="menu-details">
  <summary class="drawer__menu-item block cursor-pointer relative" aria-expanded="false">
    <button type="button" class="heading text-2xl leading-none tracking-tight"{% unless section_rendering_api %} is="api-button" data-id="DrawerSubMenu-{{ section.id }}-{{ position }}" data-section-id="{{ section.id }}"{% endunless %}>
      {{- link.title | escape -}}
    </button>
  </summary>
  <div class="drawer__submenu z-1 absolute top-0 left-0 flex flex-col w-full h-full" data-parent>
    <button type="button" class="tracking-tight heading text-base shrink-0 flex items-center gap-3 w-full" data-close>{{ link.title | escape }}</button>
    {%- unless section_rendering_api -%}
      <div id="DrawerSubMenu-{{ section.id }}-{{ position }}" class="drawer__scrollable flex flex-col h-full"></div>
    {%- else -%}
      <ul id="DrawerSubMenu-{{ section.id }}-{{ position }}" class="drawer__scrollable flex flex-col h-full">
        {%- if block.type == 'mega_menu_tab' -%}
          {%- for i in (1..5) -%}
            {%- assign tab_target_link = 'tab_target_link_' | append: i -%}
            {%- if block.settings[tab_target_link] != blank -%}
              <li class="drawer__menu-group">
                {%- liquid
                  assign tab_target = 'tab_target_' | append: i
                  assign tab_target_heading = block.settings[tab_target] | default: block.settings[tab_target_link].object.title
                  assign tab_products = 'tab_products_' | append: i
                  assign products = block.settings[tab_products] | default: block.settings[tab_target_link].object.products
                -%}
                {%- if block.settings[tab_target_link].type == 'collection_link' and products.count > 0 -%}
                  <details is="menu-details">
                    <summary class="drawer__menu-item block heading text-2xl leading-none tracking-tight cursor-pointer relative" aria-expanded="false">
                      {{- tab_target_heading | escape -}}
                    </summary>
                    <div class="drawer__submenu z-1 absolute top-0 left-0 flex flex-col w-full h-full">
                      <button type="button" class="tracking-tight heading text-base flex items-center gap-3 w-full" data-close>{{ block.settings[tab_target] | escape }}</button>
                      <div class="drawer__scrollable flex flex-col h-full">
                        <div class="horizontal-products product-grid">
                          {%- for product in products limit: 4 -%}
                            {%- render 'product-card-horizontal',
                              product: product,
                              product_id: product.id,
                              section_id: section.id,
                              block_id: block.id,
                              image_ratio: settings.product_image_ratio,
                              image_fill: settings.product_image_fill,
                              show_vendor: block.settings.show_vendor,
                              show_price: block.settings.show_price,
                              show_quick_add: settings.product_quick_add,
                              show_quick_view: settings.product_quick_view
                            -%}
                          {%- else -%}
                            {%- for i in (1..4) -%}
                              {%- render 'product-card-horizontal',
                                product: null,
                                product_id: i,
                                section_id: section.id,
                                block_id: block.id,
                                image_ratio: settings.product_image_ratio,
                                image_fill: settings.product_image_fill,
                                show_vendor: block.settings.show_vendor,
                                show_price: block.settings.show_price,
                                show_quick_add: settings.product_quick_add,
                                show_quick_view: settings.product_quick_view
                              -%}
                            {%- endfor -%}
                          {%- endfor -%}
                        </div>
                      </div>
                      <div class="drawer__sticky w-full">
                        <a class="button button--primary icon-with-text w-full" href="{{ block.settings[tab_target_link].url }}" is="hover-link">
                          <span class="btn-fill" data-fill></span>
                          <span class="btn-text">
                            {{ 'collections.subcollections.all_products' | t: collection: tab_target_heading }}
                            ({{ block.settings[tab_target_link].object.all_products_count }})
                            {%- render 'icon', icon: 'arrow-right', size: 'sm', class: 'transform' -%}
                          </span>
                        </a>
                      </div>
                    </div>
                  </details>
                {%- else -%}
                  <a class="drawer__menu-item block heading text-2xl leading-none tracking-tight" href="{{ block.settings[tab_target_link] }}">
                    {{ block.settings[tab_target] | escape }}
                  </a>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- elsif block.type == 'yg_mega_menu' -%}
          <li>
            {%- liquid
              assign show_promotions = false
              if block.settings.promo_image_1 != blank or block.settings.promo_image_2 != blank or block.settings.promo_image_3 != blank or block.settings.promo_image_4 != blank or block.settings.promo_image_5 != blank
                assign show_promotions = true
              endif
            -%}
            <div class="yg-mega-menu__container" style="--color-background: {{ block.settings.color_background.rgb }}">
              {%- unless section_rendering_api -%}
                <ul id="HeaderNavMega-{{ section.id }}-{{ position }}-{{ dir }}" class="mega-menu__list page-width{% if full_width %} page-width--full{% endif %} flex flex-wrap w-full h-full overflow-hidden" role="list" tabindex="-1">
                  {%- for i in (1..5) -%}
                    <li class="mega-menu__item flex opacity-0 w-full aspect-square">
                      <span class="media-card media-card--card w-full h-full"></span>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <ul id="HeaderNavMega-{{ section.id }}-{{ position }}-{{ dir }}" class="mega-menu__list page-width{% if full_width %} page-width--full{% endif %} flex flex-wrap w-full h-full overflow-hidden" role="list" tabindex="-1">
                  {%- if link.links != blank -%}
                    <li class="mega-menu__item mega-menu__item--nav mega-menu__item--{{ block.settings.menu_width }}{% unless show_promotions %} mega-menu__item--full{% endunless %} w-full grid">
                      <ul class="mega-menu__nav{% if link.links.size > 6 %} mega-menu__nav--more{% endif %}{% if show_promotions %} grid{% else %} flex flex-wrap{% endif %}">
                        {%- for childlink in link.links -%}
                          <li class="mega-menu__nav-item">
                            {%- if block.settings.show_menu_image and childlink.type == 'collection_link' and childlink.object.image != blank -%}
                              <a href="{{ childlink.url }}" class="media media--wide block relative overflow-hidden">
                                {{- childlink.object.image | image_url: width: childlink.object.image.width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
                              </a>
                            {%- endif -%}
                            <a href="{{ childlink.url }}" class="{% if block.settings.menu_width != 'small' %}heading {% endif %}reversed-link text-base-xl leading-tight tracking-tight{% if childlink.current %} is-active{% endif %}"{% if childlink.current %} aria-current="page"{% endif %}>
                              {{- childlink.title | escape -}}
                            </a>
                            {%- if childlink.links != blank -%}
                              <ul>
                                {%- for grandchildlink in childlink.links -%}
                                  <li>
                                    <a href="{{ grandchildlink.url }}" class="{% if block.settings.menu_width != 'small' %}reversed-link text-base xl:text-lg{% else %}heading reversed-link text-xl-3xl tracking-tighter leading-tight{% endif %}{% if grandchildlink.current %} is-active{% endif %}"{% if grandchildlink.current %} aria-current="page"{% endif %}>
                                      {{- grandchildlink.title | escape -}}
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </li>
                  {%- endif -%}
                  <li class="yg-mega-menu-tab">
                    {% for i in (1..2) %}
                      {% liquid
                        assign tab_titlei = 'tab_title' | append: i
                        assign tab_title = block.settings[tab_titlei]
                      %}
                      {% if tab_title != blank %}
                        <div class="yg-mega-menu-button{% if forloop.first %} active{% endif %}">
                          {{ tab_title }}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </li>
                  <li class="yg-mega-menu-list" >
                    <ul>
                      {%- if show_promotions -%}
                        {%- for i in (1..5) -%}
                          {%- assign promo_image = 'promo_image_' | append: i -%}
                          {%- if block.settings[promo_image] != blank -%}
                            {%- liquid
                              assign promo_image_ratio = 'promo_image_ratio_' | append: i
                              assign promo_heading = 'promo_heading_' | append: i
                              assign promo_subtext = 'promo_subtext_' | append: i
                              assign promo_overlay_content = 'promo_overlay_content_' | append: i
                              assign promo_link = 'promo_link_' | append: i
                              assign promo_tag = 'promo_tag_' | append: i
                              assign promo_color_text = 'promo_color_text_' | append: i
                              assign promo_color_overlay = 'promo_color_overlay_' | append: i
                              assign promo_overlay_opacity = 'promo_overlay_opacity_' | append: i
                            -%}
                            <li class="mega-menu__item flex  w-full{% if link.links != blank %} align-self-start{% endif %}">
                              <div class="media-card media-card--{{ settings.card_style }}{% if block.settings[promo_overlay_content] %} media-card--overlap{% endif %}">
                                <a class="media-card__link flex flex-col w-full h-full relative"{% if block.settings[promo_link] != blank %} href="{{ block.settings[promo_link] }}"{% else %} role="link" aria-disabled="true"{% endif %}
                                   aria-label="{{ block.settings[promo_heading] | default: block.settings[promo_subtext] | escape }}"
                                   style="--color-foreground: {{ block.settings[promo_color_text].rgb }}; --color-overlay: {{ block.settings[promo_color_overlay].rgb }}; --overlay-opacity: {{ block.settings[promo_overlay_opacity] | divided_by: 100.0 }};"
                                >
                                  {%- if block.settings[promo_tag] != blank -%}
                                    <div class="badges z-2 absolute grid gap-3 pointer-events-none">
                                      <span class="badge badge--onsale flex items-center gap-1d5 font-medium leading-none rounded-full">{{ block.settings[promo_tag] | escape }}</span>
                                    </div>
                                  {%- endif -%}
                                  <div class="media media--{{ block.settings[promo_image_ratio] }} relative overflow-hidden">
                                    {{- block.settings[promo_image] | image_url: width: block.settings[promo_image].width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
                                  </div>
                                  {%- if block.settings[promo_heading] != blank or block.settings[promo_subtext] != blank -%}
                                    <div class="media-card__content flex justify-between items-center gap-4 w-full">
                                      <div class="media-card__text shrink-1 grid gap-0d5">
                                        {%- if block.settings[promo_heading] != blank -%}
                                          <p>
                                            <span class="heading reversed-link text-xl-3xl tracking-tighter leading-tight">{{ block.settings[promo_heading] | escape }}</span>
                                          </p>
                                        {%- endif -%}
                                        {%- if block.settings[promo_subtext] != blank -%}
                                          <p class="leading-none text-xs">{{ block.settings[promo_subtext] }}</p>
                                        {%- endif -%}
                                      </div>
                                      {%- render 'icon', icon: 'arrow-right', size: 'xs', class: 'transform shrink-0 hidden xl:block' -%}
                                    </div>
                                  {%- endif -%}
                                </a>
                              </div>
                            </li>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                    </ul>
                  </li>
                  <li class="yg-mega-menu-collections" style="display: none">
                    <ul>
                      <li class="mega-menu__item mega-menu__item--tabs w-full flex flex-col gap-8">
                        {%- if block.settings.heading_1 != blank -%}
                          <p class="text-base xl:text-lg font-medium">{{ block.settings.heading_1 | escape }}</p>
                        {%- endif -%}
                        <tabs-element class="mega-menu__nav mega-menu__nav--tabs grid gap-1d5">
                          {%- liquid
                            assign forloop_first = true
                            assign forloop_index = 0
                          -%}
                          {%- for menu in block.settings.menu_2.links -%}
                            {%- if menu.url != blank -%}
                              {%- capture tab_heading -%}
                                <span
                                  class="heading link-text text-xl-3xl tracking-tighter leading-tight">{{ menu.title | escape }}</span>
                              {%- endcapture -%}
                              <button type="button"
                                      class="mega-menu__nav-item flex gap-2 items-center  link icon-with-text" role="tab"
                                      aria-controls="TabPanel-{{ block.id }}-{{ forloop_index }}"
                                      data-index="{{ forloop_index }}"{% if forloop_first %} disabled{% endif %}>
                                {{- tab_heading -}}
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                  <path fill-rule="evenodd" clip-rule="evenodd" d="M7.29289 15.7071C6.90237 15.3166 6.90237 14.6834 7.29289 14.2929L11.5858 10L7.29289 5.70711C6.90237 5.31658 6.90237 4.68342 7.29289 4.29289C7.68342 3.90237 8.31658 3.90237 8.70711 4.29289L13.7071 9.29289C13.8946 9.48043 14 9.73478 14 10C14 10.2652 13.8946 10.5196 13.7071 10.7071L8.70711 15.7071C8.31658 16.0976 7.68342 16.0976 7.29289 15.7071Z" fill="currentColor"/>
                                </svg>
                              </button>
                              {%- liquid
                                assign forloop_first = false
                                assign forloop_index = forloop_index | plus: 1
                              -%}
                            {%- endif -%}
                          {%- endfor -%}
                        </tabs-element>
                      </li>
                      <li class="mega-menu__item mega-menu__item--panels w-full">
                        {%- liquid
                          assign forloop_first = true
                          assign forloop_index = 0
                        -%}
                        {%- for menu in block.settings.menu_2.links -%}
                          {%- if menu.url != blank -%}
                            {% assign products = menu.object.products %}
                            <div id="TabPanel-{{ block.id }}-{{ forloop_index }}"
                                 class="mega-menu__panel flex w-full"
                                 role="tabpanel"{% unless forloop_first %} hidden{% endunless %}>
                              <div class="grid gap-8">
                                <motion-list class="product-grid card-grid card-grid--4 mobile:card-grid--1 grid" initialized>
                                  {%- for product in products limit: 4 -%}
                                    {% render 'yg-menu-card',
                                      product: product,
                                      product_id: product.id,
                                      section_id: section.id,
                                      block_id: block.id,
                                      lazy_load: false,
                                      image_ratio: settings.product_image_ratio,
                                      image_fill: settings.product_image_fill,
                                      show_secondary_image: settings.product_secondary_image,
                                      show_vendor: settings.product_vendor,
                                      show_rating: settings.product_rating,
                                      show_color_swatches: settings.product_color_swatches,
                                      show_countdown: settings.product_countdown,
                                      show_quick_add: settings.product_quick_add,
                                      show_quick_view: settings.product_quick_view,
                                      show_save_amount: settings.product_save_amount,
                                      save_type: settings.product_save_type,
                                      show_icon_list: false
                                    %}
                                  {%- else -%}
                                    {%- for i in (1..4) -%}
                                      {%- capture placeholder -%}product-{% cycle '1', '2', '3', '4' %}{%- endcapture -%}
                                      {%- render 'product-card-placeholder',
                                        lazy_load: false,
                                        image_ratio: settings.product_image_ratio,
                                        image_fill: settings.product_image_fill,
                                        show_secondary_image: settings.product_secondary_image,
                                        show_vendor: settings.product_vendor,
                                        show_rating: settings.product_rating,
                                        show_color_swatches: settings.product_color_swatches,
                                        show_countdown: settings.product_countdown,
                                        show_quick_add: settings.product_quick_add,
                                        show_quick_view: settings.product_quick_view,
                                        show_save_amount: settings.product_save_amount,
                                        save_type: settings.product_save_type,
                                        placeholder: placeholder
                                      -%}
                                    {%- endfor -%}
                                  {%- endfor -%}
                                </motion-list>
                                <div class="flex items-center justify-center gap-4">
                                  {%- if menu.url != blank -%}
                                    <div class="mega-menu__footer-link relative">
                                      {%- render 'button',
                                        label: 'View All',
                                        link: menu.url,
                                        classes: 'mega-menu__link button--fixed',
                                        shopify_attributes: block.shopify_attributes
                                      -%}
                                    </div>
                                  {%- endif -%}
                                </div>
                              </div>
                              {%- if block.settings.menu2_image != blank -%}
                                {%- liquid
                                  assign promo_image = block.settings.menu2_image
                                  assign promo_image_ratio = block.settings.menu2_image_ratio
                                  assign promo_heading = block.settings.menu2_heading
                                  assign promo_overlay_content = block.settings.menu2_content
                                  assign promo_link = block.settings.menu2_link
                                  assign promo_label = block.settings.menu2_label
                                -%}
                                <div
                                  class="media-card media-card--{{ settings.card_style }} media-card--overlap" style="display: none">
                                  <div
                                    class="media-card__link flex flex-col w-full h-full relative"
                                    aria-label="{{ promo_heading }}"
                                    style="--color-foreground: {{ block.settings[promo_color_text].rgb }}; --color-overlay: {{ block.settings[promo_color_overlay].rgb }}; --overlay-opacity: {{ block.settings[promo_overlay_opacity] | divided_by: 100.0 }};"
                                  >
                                    <div class="media media--{{ promo_image_ratio }} relative overflow-hidden">
                                      {{- promo_image | image_url: width: promo_image.width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
                                    </div>
                                    {%- if promo_heading != blank -%}
                                      <div class="media-card__content flex justify-between items-center gap-4 w-full">
                                        <div class="media-card__text shrink-1 grid gap-0d5">
                                          {%- if promo_heading != blank -%}
                                            <p>
                                <span
                                  class="heading reversed-link text-xl-3xl tracking-tighter leading-tight">{{ promo_heading | escape }}</span>
                                            </p>
                                          {%- endif -%}
                                          {%- if promo_overlay_content != blank -%}
                                            <p class="leading-none text-xs">{{ promo_overlay_content }}</p>
                                          {%- endif -%}
                                          {%- if menu.url != blank -%}
                                            <div class="mega-menu__footer-link yg-promo-menu-link relative">
                                              {%- render 'button',
                                                label: promo_label,
                                                link: promo_link,
                                                classes: 'mega-promo-link button--blur',
                                                shopify_attributes: block.shopify_attributes
                                              -%}
                                            </div>
                                          {%- endif -%}
                                        </div>
                                        {%- render 'icon', icon: 'arrow-right', size: 'xs', class: 'transform shrink-0 hidden xl:block' -%}
                                      </div>
                                    {%- endif -%}
                                  </div>
                                </div>
                              {%- endif -%}
                            </div>
                            {%- liquid
                              assign forloop_first = false
                              assign forloop_index = forloop_index | plus: 1
                            -%}
                          {%- endif -%}
                        {%- endfor -%}
                      </li>
                    </ul>
                  </li>
                </ul>
              {%- endunless -%}
            </div>
          </li>
        {%- else -%}
          {%- for childlink in link.links -%}
            <li class="drawer__menu-group">
              {%- if childlink.links != blank -%}
                <details is="menu-details">
                  <summary class="drawer__menu-item block heading text-2xl leading-none tracking-tight cursor-pointer relative" aria-expanded="false">
                    {{- childlink.title | escape -}}
                  </summary>
                  <div class="drawer__submenu z-1 absolute top-0 left-0 flex flex-col w-full h-full">
                    <button type="button" class="tracking-tight heading text-base flex items-center gap-3 w-full" data-close>{{ childlink.title | escape }}</button>
                    <ul class="drawer__scrollable flex flex-col h-full">
                      {%- for grandchildlink in childlink.links -%}
                        <li class="drawer__menu-group">
                          <a class="drawer__menu-item block heading text-2xl leading-none tracking-tight" href="{{ grandchildlink.url }}">{{ grandchildlink.title | escape }}</a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </details>
              {%- else -%}
                <a class="drawer__menu-item block heading text-2xl leading-none tracking-tight" href="{{ childlink.url }}">{{ childlink.title | escape }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- endif -%}

        {%- if enable_mega_menu -%}
          {%- liquid
            assign show_promotions = false
            
            if block.settings.promo_image_1 != blank or block.settings.promo_image_2 != blank or block.settings.promo_image_3 != blank or block.settings.promo_image_4 != blank or block.settings.promo_image_5 != blank
              assign show_promotions = true
            endif

            if block.type == 'yg_mega_menu'
              if block.settings.promo_image_1 != blank or block.settings.promo_image_2 != blank or block.settings.promo_image_3 != blank or block.settings.promo_image_4 != blank or block.settings.promo_image_5 != blank
                assign show_promotions = false
              endif
            endif
            if block.type == 'mega_menu_tab'
              if block.settings.tab_target_link_1 == blank and block.settings.tab_target_link_2 == blank and block.settings.tab_target_link_3 == blank and block.settings.tab_target_link_4 == blank and block.settings.tab_target_link_5 == blank
                assign show_promotions = false
              endif
            endif
          -%}
        {%- endif -%}
        {%- if show_promotions -%}
          <li class="drawer__menu-group drawer__promotions">
            <ul class="mega-menu__list grid grid-cols-2 w-full h-full" role="list" tabindex="-1">
              {%- for i in (1..5) -%}
                {%- liquid
                  assign show_promotion = false
                  
                  assign promo_image = 'promo_image_' | append: i
                  if block.settings[promo_image] != blank
                    assign show_promotion = true
                  endif
                  
                  if block.type == 'mega_menu_tab'
                    assign tab_target_link = 'tab_target_link_' | append: i
                    if block.settings[tab_target_link] == blank
                      assign show_promotion = false
                    endif
                  endif
                -%}
                {%- if show_promotion -%}
                  {%- liquid
                    assign promo_image_ratio = 'promo_image_ratio_' | append: i
                    assign promo_heading = 'promo_heading_' | append: i
                    assign promo_subtext = 'promo_subtext_' | append: i
                    assign promo_overlay_content = 'promo_overlay_content_' | append: i
                    assign promo_link = 'promo_link_' | append: i
                    assign promo_tag = 'promo_tag_' | append: i
                    assign promo_color_text = 'promo_color_text_' | append: i
                    assign promo_color_overlay = 'promo_color_overlay_' | append: i
                    assign promo_overlay_opacity = 'promo_overlay_opacity_' | append: i
                  -%}
                  <li class="drawer__menu-group mega-menu__item flex opacity-0 w-full">
                    <div class="media-card media-card--{{ settings.card_style }}{% if block.settings[promo_overlay_content] %} media-card--overlap{% endif %}">
                      <a class="media-card__link flex flex-col w-full h-full relative"{% if block.settings[promo_link] != blank %} href="{{ block.settings[promo_link] }}"{% else %} role="link" aria-disabled="true"{% endif %}
                        aria-label="{{ block.settings[promo_heading] | default: block.settings[promo_subtext] | escape }}"
                        style="--color-foreground: {{ block.settings[promo_color_text].rgb }}; --color-overlay: {{ block.settings[promo_color_overlay].rgb }}; --overlay-opacity: {{ block.settings[promo_overlay_opacity] | divided_by: 100.0 }};"
                      >
                        {%- if block.settings[promo_tag] != blank -%}
                          <div class="badges z-2 absolute grid gap-3 pointer-events-none">
                            <span class="badge badge--onsale flex items-center gap-1d5 font-medium leading-none rounded-full">{{ block.settings[promo_tag] | escape }}</span>
                          </div>
                        {%- endif -%}
                        <div class="media media--{{ block.settings[promo_image_ratio] }} relative overflow-hidden">
                          {{- block.settings[promo_image] | image_url: width: block.settings[promo_image].width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
                        </div>
                        {%- if block.settings[promo_heading] != blank or block.settings[promo_subtext] != blank -%}
                          <div class="media-card__content flex justify-between items-center gap-4 w-full">
                            <div class="media-card__text opacity-0 shrink-1 grid gap-0d5">
                              {%- if block.settings[promo_heading] != blank -%}
                                <p>
                                  <span class="heading reversed-link text-lg tracking-tighter leading-tight">{{ block.settings[promo_heading] | escape }}</span>
                                </p>
                              {%- endif -%}
                              {%- if block.settings[promo_subtext] != blank -%}
                                <p class="leading-none text-xs xl:text-sm hidden md:block">{{ block.settings[promo_subtext] }}</p>
                              {%- endif -%}
                            </div>
                            {%- render 'icon', icon: 'arrow-right', size: 'xs', class: 'transform shrink-0 hidden md:block' -%}
                          </div>
                        {%- endif -%}
                      </a>
                    </div>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </li>
        {%- endif -%}
        {%  unless block.type == 'yg_mega_menu' %}
        {%- if block.settings.button_label != blank -%}
          <li class="mega-menu__footer">
            <a class="button button--primary icon-with-text w-full"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% if block.settings.button_external %} target="_blank" rel="noopener"{% endif %}{% else %} role="link" aria-disabled="true"{% endif %} is="hover-link">
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">{{ block.settings.button_label | escape }}</span>
            </a>
          </li>
        {%- endif -%}
        {% endunless %}
      </ul>
    {%- endunless -%}
  </div>
</details>
